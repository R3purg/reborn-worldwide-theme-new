    "rw_about_story_1": {
      "type": "rw-about-story",
      "blocks": {
        "row_1": {
          "type": "row",
          "settings": {
            "side": "left",
            "image_alt": "The Kraków garage — two borrowed screens",
            "kicker": "// HOW IT STARTED",
            "heading": "It started in a garage with a borrowed rig.",
            "body": "<p>No business plan, no investors, no warehouse. Just two screens, a kettle that's seen things, and a stubborn idea: make clothes that argue with you a little, and make them so well you can't ignore them. Chapter 01 sold out over a weekend. We've never made it again.</p>"
          }
        },
        "row_2": {
          "type": "row",
          "settings": {
            "side": "right",
            "image_alt": "Lena at the light table — designing a chapter",
            "kicker": "// HOW WE WORK",
            "heading": "We write the story before we cut the cloth.",
            "body": "<p>Every chapter is built around a character and a world, not a season. We design the pieces to live inside that story, make exactly 250, drop them once, and move on. It's slower, harder, and far more fun than chasing a trend calendar.</p>"
          }
        }
      },
      "block_order": ["row_1", "row_2"],
      "settings": {
        "color_scheme": "scheme-1"
      }
    },
    "rw_about_values_1": {
      "type": "rw-about-values",
      "blocks": {
        "val_1": {
          "type": "value",
          "settings": {
            "title": "Make less",
            "body": "Four chapters a year, 250 pieces each. Scarcity isn't a tactic — it's the only way four people make things they're proud of."
          }
        },
        "val_2": {
          "type": "value",
          "settings": {
            "title": "By hand",
            "body": "Every piece pulled on our own screens, water-based ink, in the room we work in. No third-party factory, no middlemen."
          }
        },
        "val_3": {
          "type": "value",
          "settings": {
            "title": "No restocks",
            "body": "When a chapter sells out, it's gone. The work stays honest because we can't lean on a warehouse of safe reprints."
          }
        },
        "val_4": {
          "type": "value",
          "settings": {
            "title": "From the East",
            "body": "Born in a Kraków garage, grown across Berlin and Lisbon. The most interesting streetwear isn't where you think it is."
          }
        }
      },
      "block_order": ["val_1", "val_2", "val_3", "val_4"],
      "settings": {
        "heading": "What we stand on",
        "sub_copy": "Four rules we've never broken, even when it cost us.",
        "color_scheme": "scheme-4"
      }
    },
