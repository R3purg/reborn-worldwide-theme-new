    "rw_about_hero_1": {
      "type": "rw-about-hero",
      "settings": {
        "kicker": "// ABOUT — REBORN WORLDWIDE",
        "meta_line": "EST. KRAKÓW 2024",
        "heading_line_1": "FOUR PEOPLE.",
        "heading_accent": "ONE",
        "heading_line_2": "STUBBORN IDEA.",
        "intro": "<p>Reborn is an independent streetwear studio making clothes for people who were told to sit down — and didn't. We release in chapters, by hand, and we never look back.</p>",
