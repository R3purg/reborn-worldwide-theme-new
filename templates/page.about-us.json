    "rw_about_timeline_1": {
      "type": "rw-about-timeline",
      "blocks": {
        "ms_1": {
          "type": "milestone",
          "settings": {
            "year": "2024",
            "title": "The garage",
            "body": "Two borrowed screens, a kettle, and a refusal to print logos on blanks. Chapter 01 — My Swamp — sells out in a weekend."
          }
        },
        "ms_2": {
          "type": "milestone",
          "settings": {
            "year": "2025",
            "title": "Three cities",
            "body": "Berlin showroom opens, Lisbon studio follows. Chapters 02 and 03 evaporate in minutes. The list grows past 40k."
          }
        },
        "ms_3": {
          "type": "milestone",
          "settings": {
            "year": "2026",
            "title": "Vol. 04",
            "body": "Chapter 04 — Bikini Bling — drops worldwide. Same four people. Same screens. Still no restocks."
          }
        }
      },
      "block_order": ["ms_1", "ms_2", "ms_3"],
      "settings": {
        "kicker": "// THE SHORT HISTORY",
        "heading": "How we got here",
        "color_scheme": "scheme-1"
      }
