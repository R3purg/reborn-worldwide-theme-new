{% liquid
  assign s = section.settings
  assign center_items = s.center_messages | default: "NEXT DROP // CHAPTER 04 — FRI 22:00 CET\nSTUDIO // KRAKÓW · BERLIN · LISBON" | newline_to_br | split: '<br />'
%}

<aside
  class="rw-announce color-{{ s.color_scheme }}"
  data-section-id="{{ section.id }}"
  id="rw-announce-{{ section.id }}"
  aria-label="Store announcements"
>
  <div class="rw-announce__inner">
    <div class="rw-announce__left">
      {{ s.left_text | default: 'SHIP // WORLDWIDE — FREE OVER €120' }}
    </div>

    <div class="rw-announce__center" aria-label="Current announcements">
      {%- for msg in center_items -%}
        <span class="rw-announce__msg">{{- msg | strip -}}</span>
        {%- unless forloop.last -%}
          <span class="rw-announce__sep" aria-hidden="true"> /// </span>
        {%- endunless -%}
      {%- endfor -%}
    </div>

    <div class="rw-announce__right">
      {%- if localization.available_countries.size > 1 -%}
        {% form 'localization', id: 'rw-announce-loc-{{ section.id }}', class: 'rw-announce__loc-form' %}
          <select
            name="country_code"
            class="rw-announce__select"
            aria-label="Select country"
            onchange="this.form.submit()"
          >
            {%- for country in localization.available_countries -%}
              <option
                value="{{ country.iso_code }}"
                {%- if country.iso_code == localization.country.iso_code %}
                  selected
                {%- endif -%}
              >
                {{ country.currency.iso_code }}
                {{ country.currency.symbol }}
              </option>
            {%- endfor -%}
          </select>
        {% endform %}
      {%- else -%}
        <span>{{- localization.country.currency.iso_code }} {{ localization.country.currency.symbol -}}</span>
      {%- endif -%}
      <span class="rw-announce__lang">{{ request.locale.iso_code | upcase | slice: 0, 2 }}</span>
    </div>
  </div>
</aside>

{% stylesheet %}
  .rw-announce {
    border-bottom: 1px solid #000;
  }

  .rw-announce__inner {
    max-width: 1440px;
    margin-inline: auto;
    padding: 8px 24px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
  }

  .rw-announce__left,
  .rw-announce__center,
  .rw-announce__right,
  .rw-announce__msg,
  .rw-announce__sep,
  .rw-announce__lang {
    font-family: var(--font-accent--family, 'JetBrains Mono', ui-monospace, monospace);
    font-size: 11px;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .rw-announce__left {
    opacity: 0.85;
    white-space: nowrap;
  }

  .rw-announce__center {
    display: flex;
    align-items: center;
    justify-content: center;
    flex: 1;
    min-width: 0;
    white-space: nowrap;
    overflow: hidden;
    opacity: 0.85;
    gap: 18px;
  }

  .rw-announce__sep {
    opacity: 0.4;
    margin-inline: 0;
  }

  .rw-announce__right {
    display: flex;
    align-items: center;
    gap: 14px;
    white-space: nowrap;
  }

  .rw-announce__lang {
    opacity: 0.6;
  }

  .rw-announce__select {
    appearance: none;
    -webkit-appearance: none;
    background: transparent;
    color: inherit;
    border: 1px solid rgba(255, 255, 255, 0.25);
    border-radius: 999px;
    padding: 4px 10px;
    font: inherit;
    cursor: pointer;
  }

  .rw-announce__loc-form {
    display: inline-flex;
  }

{% endstylesheet %}

{% schema %}
{
  "name": "RW Announcement",
  "enabled_on": {
    "groups": ["header"]
  },
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:settings.color_scheme",
      "default": "scheme-4"
    },
    {
      "type": "text",
      "id": "left_text",
      "label": "Left text",
      "default": "SHIP // WORLDWIDE — FREE OVER €120"
    },
    {
      "type": "textarea",
      "id": "center_messages",
      "label": "Centre messages (one per line)",
      "info": "Each line is shown inline in the center strip.",
      "placeholder": "NEXT DROP // CHAPTER 04 — FRI 22:00 CET\nSTUDIO // KRAKÓW · BERLIN · LISBON"
    }
  ],
  "presets": [
    {
      "name": "RW Announcement"
    }
  ]
}
{% endschema %}
