{%- liquid
  assign threshold_cents = section.settings.free_shipping_threshold | times: 100
  assign cart_total = cart.total_price
  assign remaining_cents = threshold_cents | minus: cart_total | at_least: 0
  assign remaining = remaining_cents | money
  assign pct = 0
  if threshold_cents > 0
    assign pct = cart_total | times: 100 | divided_by: threshold_cents | at_most: 100
  endif
  assign count = cart.item_count
-%}

<div class="section--{{ section.settings.section_width }}">
  <div
    class="rw-cart-hdr{% if cart.empty? %} rw-cart-hdr--empty{% endif %}"
    id="rw-cart-hdr-{{ section.id }}"
    data-rw-cart-hdr
    data-initial-item-count="{{ cart.item_count }}"
    data-initial-total-price="{{ cart.total_price }}"
    data-free-shipping-threshold-cents="{{ threshold_cents }}"
    data-free-shipping-enabled="{{ section.settings.show_free_shipping_bar }}"
    style="padding-block-start: {{ section.settings.padding_top }}px; padding-block-end: {{ section.settings.padding_bottom }}px;"
  >
    <nav
      class="rw-cart-hdr__breadcrumb"
      {% if cart.empty? %}
        hidden
      {% endif %}
      aria-label="Breadcrumbs"
      data-rw-cart-hdr-breadcrumb
    >
      <a href="{{ routes.root_url }}" class="rw-cart-hdr__bc-link">HOME</a>
      <span aria-hidden="true"> / </span>
      <span aria-current="page">BAG</span>
    </nav>

    <div
      class="rw-cart-hdr__title-row{% if cart.empty? %} rw-cart-hdr__title-row--empty{% endif %}"
      data-rw-cart-hdr-row
    >
      <h1
        class="rw-cart-hdr__title{% if cart.empty? %} rw-cart-hdr__title--empty{% endif %}"
        data-rw-cart-hdr-title
        data-filled-text="YOUR BAG"
        data-empty-text="It&#8217;s empty in here."
      >
        <span class="rw-cart-hdr__title-text" data-rw-cart-hdr-title-text>
          {%- if cart.empty? -%}
            It&#8217;s empty in here.
          {%- else -%}
            YOUR BAG
          {%- endif -%}
        </span>
        <sup
          class="rw-cart-hdr__count"
          data-rw-cart-hdr-count
          {% if cart.empty? %}
            hidden
          {% endif %}
        >
          {%- if count < 10 -%}0{{ count }}{%- else -%}{{ count }}{%- endif -%}
        </sup>
      </h1>
      <a
        href="{{ routes.all_products_collection_url }}"
        class="rw-cart-hdr__keep-shopping"
        data-rw-cart-hdr-keep-shopping
        {% if cart.empty? %}
          hidden
        {% endif %}
      >
        &#8592; Keep shopping
      </a>
    </div>

    <p
      class="rw-cart-hdr__empty-sub"
      {% unless cart.empty? %}
        hidden
      {% endunless %}
      data-rw-cart-hdr-empty-sub
    >
      // AS EMPTY AS A MONDAY MORNING. GO FIX THAT.
    </p>

    {%- if section.settings.show_free_shipping_bar -%}
      <div
        class="rw-cart-progress rw-cart-progress--page"
        data-rw-cart-hdr-progress
        data-rw-cart-hdr-progress-enabled="true"
        {% if cart.empty? %}
          hidden
        {% endif %}
      >
        <div class="rw-cart-progress__label">
          <span data-rw-cart-hdr-progress-text>
            {%- if remaining_cents <= 0 -%}
              // FREE WORLDWIDE SHIPPING UNLOCKED
            {%- else -%}
              // {{ remaining }} TO FREE WORLDWIDE SHIPPING
            {%- endif -%}
          </span>
          <span data-rw-cart-hdr-progress-percent>{{ pct }}%</span>
        </div>
        <div class="rw-cart-progress__track">
          <div class="rw-cart-progress__fill" style="width: {{ pct }}%" data-rw-cart-hdr-progress-fill></div>
        </div>
      </div>
    {%- endif -%}
  </div>
</div>

{% stylesheet %}
  .rw-cart-hdr {
    padding-inline: var(--page-margin, 1.5rem);
  }

  .rw-cart-hdr__breadcrumb {
    display: flex;
    gap: 6px;
    align-items: center;
    margin-bottom: 20px;
    font-family: var(--font-accent--family, 'JetBrains Mono', ui-monospace, monospace);
    font-size: 11px;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: rgba(var(--color-foreground-rgb), 0.62);
  }

  .rw-cart-hdr__bc-link {
    color: inherit;
    text-decoration: none;
  }

  .rw-cart-hdr__bc-link:hover {
    text-decoration: underline;
  }

  .rw-cart-hdr__title-row {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    gap: 24px;
    flex-wrap: wrap;
    margin-bottom: 32px;
  }

  .rw-cart-hdr__title-row--empty {
    justify-content: center;
    margin-bottom: 16px;
  }

  .rw-cart-hdr__title {
    font-family: var(--font-heading--family, 'Anton', 'Oswald', sans-serif);
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 0.005em;
    font-size: clamp(52px, 10vw, 160px);
    line-height: 0.95;
    margin: 0;
  }

  .rw-cart-hdr__title--empty {
    font-size: clamp(40px, 6vw, 88px);
    text-align: center;
  }

  .rw-cart-hdr__title-text {
    display: inline-block;
  }

  .rw-cart-hdr__count {
    color: rgb(var(--color-button));
    font-size: 0.4em;
    vertical-align: super;
    line-height: 1;
  }

  .rw-cart-hdr__keep-shopping {
    font-family: var(--font-accent--family, 'JetBrains Mono', ui-monospace, monospace);
    font-size: 11px;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    text-decoration: underline;
    color: rgba(var(--color-foreground-rgb), 0.62);
    padding-bottom: 10px;
    white-space: nowrap;
  }

  .rw-cart-hdr__keep-shopping:hover {
    color: rgb(var(--color-foreground));
  }

  .rw-cart-hdr__empty-sub {
    font-family: var(--font-accent--family, 'JetBrains Mono', ui-monospace, monospace);
    font-size: 11px;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: rgba(var(--color-foreground-rgb), 0.62);
    text-align: center;
    margin: 0 0 32px;
  }

  /* Page variant of free-ship progress bar */
  .rw-cart-progress--page {
    border: 1px solid rgb(var(--color-foreground));
    padding: 18px 20px;
    margin-bottom: 24px;
  }

  @media screen and (min-width: 750px) {
    .rw-cart-progress--page {
      margin-inline-end: calc(min(50vw, var(--sidebar-width, 25rem)) + var(--padding-5xl, 3rem));
    }
  }

  .rw-cart-progress--page .rw-cart-progress__label {
    display: flex;
    justify-content: space-between;
    gap: 16px;
    color: rgb(var(--color-foreground));
    margin-bottom: 10px;
  }

  .rw-cart-progress--page .rw-cart-progress__track {
    height: 6px;
  }

  /* Hide the default _cart-title block — replaced by this section */
  .cart-page__title {
    display: none;
  }

  /* Style the empty-cart CTA to match the brand button system */
  .cart-page--empty .cart-items__empty-button {
    font-family: var(--font-accent--family, 'JetBrains Mono', ui-monospace, monospace);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    border: 1px solid rgb(var(--color-foreground));
    border-radius: 999px;
    background: rgb(var(--color-foreground));
    color: rgb(var(--color-background));
    padding: 18px 28px;
    font-size: 14px;
    transition: transform 0.2s ease;
  }

  .cart-page--empty .cart-items__empty-button:hover {
    transform: translateY(-2px);
    box-shadow: none;
  }

  .rw-cart-hdr--empty .rw-cart-hdr__title-row {
    justify-content: center;
  }

  .rw-cart-hdr--empty .rw-cart-hdr__keep-shopping {
    display: none;
  }

  .rw-cart-hdr--empty .rw-cart-progress--page {
    display: none;
  }
{% endstylesheet %}

{% javascript %}
  (function () {
    const root = document.querySelector('[data-rw-cart-hdr]');
    if (!root) return;

    const title = root.querySelector('[data-rw-cart-hdr-title]');
    const titleText = root.querySelector('[data-rw-cart-hdr-title-text]');
    const count = root.querySelector('[data-rw-cart-hdr-count]');
    const breadcrumb = root.querySelector('[data-rw-cart-hdr-breadcrumb]');
    const keepShopping = root.querySelector('[data-rw-cart-hdr-keep-shopping]');
    const emptySub = root.querySelector('[data-rw-cart-hdr-empty-sub]');
    const progress = root.querySelector('[data-rw-cart-hdr-progress]');
    const progressText = root.querySelector('[data-rw-cart-hdr-progress-text]');
    const progressPercent = root.querySelector('[data-rw-cart-hdr-progress-percent]');
    const progressFill = root.querySelector('[data-rw-cart-hdr-progress-fill]');
    const row = root.querySelector('[data-rw-cart-hdr-row]');
    const thresholdCents = Number(root.dataset.freeShippingThresholdCents || 0);
    const progressEnabled = root.dataset.freeShippingEnabled === 'true';
    const filledText = title?.dataset.filledText || 'YOUR BAG';
    const emptyText = title?.dataset.emptyText || 'It’s empty in here.';

    const moneyCurrency = () => window.Shopify?.currency?.active || 'EUR';
    const formatMoney = (cents) =>
      (Math.max(0, Number(cents) || 0) / 100).toLocaleString(undefined, {
        style: 'currency',
        currency: moneyCurrency(),
        minimumFractionDigits: 2,
      });

    const setHidden = (el, hidden) => {
      if (!el) return;
      el.hidden = hidden;
    };

    const syncHeader = (cartData) => {
      const itemCount = Number(cartData?.item_count ?? 0);
      const totalPrice = Number(cartData?.total_price ?? 0);
      const isEmpty = itemCount <= 0;

      root.classList.toggle('rw-cart-hdr--empty', isEmpty);
      row?.classList.toggle('rw-cart-hdr__title-row--empty', isEmpty);

      if (titleText) titleText.textContent = isEmpty ? emptyText : filledText;
      if (count) {
        count.hidden = isEmpty;
        count.textContent = isEmpty ? '' : String(itemCount).padStart(2, '0');
      }

      setHidden(breadcrumb, isEmpty);
      setHidden(keepShopping, isEmpty);
      setHidden(emptySub, !isEmpty);

      if (!progress || !progressEnabled || thresholdCents <= 0) return;

      setHidden(progress, isEmpty);

      if (isEmpty) return;

      const remainingCents = Math.max(0, thresholdCents - totalPrice);
      const pct = Math.min(100, Math.round((totalPrice / thresholdCents) * 100));

      if (progressText) {
        progressText.textContent =
          remainingCents <= 0
            ? '// FREE WORLDWIDE SHIPPING UNLOCKED'
            : `// ${formatMoney(remainingCents)} TO FREE WORLDWIDE SHIPPING`;
      }

      if (progressPercent) progressPercent.textContent = `${pct}%`;
      if (progressFill) progressFill.style.width = `${pct}%`;
    };

    syncHeader({
      item_count: Number(root.dataset.initialItemCount || 0),
      total_price: Number(root.dataset.initialTotalPrice || 0),
    });

    const onCartUpdate = (event) => {
      const cartData = event?.detail?.resource || {};
      if (cartData.item_count === undefined && event?.detail?.data?.itemCount !== undefined) {
        cartData.item_count = Number(event.detail.data.itemCount);
      }
      syncHeader(cartData);
    };

    if (window.__rwCartHeaderOnCartUpdate) {
      document.removeEventListener('cart:update', window.__rwCartHeaderOnCartUpdate);
    }

    window.__rwCartHeaderOnCartUpdate = onCartUpdate;
    document.addEventListener('cart:update', onCartUpdate);
  })();
{% endjavascript %}

{% schema %}
{
  "name": "Cart Header",
  "enabled_on": {
    "templates": ["cart"]
  },
  "settings": [
    {
      "type": "checkbox",
      "id": "show_free_shipping_bar",
      "label": "Show free shipping progress bar",
      "default": true
    },
    {
      "type": "number",
      "id": "free_shipping_threshold",
      "label": "Free shipping threshold",
      "info": "Amount in your main currency unit (e.g. 120 for €120)",
      "default": 120
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "Width",
      "options": [
        { "value": "page-width", "label": "Page" },
        { "value": "full-width", "label": "Full" }
      ],
      "default": "page-width"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "Cart Header"
    }
  ]
}
{% endschema %}
