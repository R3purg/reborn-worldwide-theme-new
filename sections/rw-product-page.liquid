      "label": "Size guide URL"
    },
    {
      "type": "header",
      "content": "Trust row"
    },
    {
      "type": "text",
      "id": "trust_shipping",
      "label": "Shipping value",
      "default": "over €120"
    },
    {
      "type": "text",
      "id": "trust_returns_label",
      "label": "Returns label",
      "default": "14-DAY"
    },
    {
      "type": "text",
      "id": "trust_returns",
      "label": "Returns value",
      "default": "returns"
    },
    {
      "type": "text",
      "id": "trust_made_in_label",
      "label": "Made in label",
      "default": "HAND-MADE"
    },
    {
      "type": "text",
      "id": "trust_made_in",
      "label": "Made in value",
      "default": "in Kraków"
    },
    {
      "type": "header",
      "content": "Accordions"
    },
    {
      "type": "richtext",
      "id": "details_and_fit",
      "label": "Details & Fit",
      "info": "Overridden per-product via custom.details_and_fit metafield."
