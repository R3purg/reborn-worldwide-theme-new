{% liquid
  assign s = section.settings
  assign rw_pw_words = s.ticker_text | split: ','
%}

<div class="rw-pw-ticker color-{{ s.color_scheme }}">
  <div class="rw-pw-ticker__track" aria-hidden="true">
    {%- for rep in (1..2) -%}
      <span class="rw-pw-ticker__group">
        {%- for word in rw_pw_words -%}
          <span class="rw-pw-ticker__item">
            <span class="rw-pw-ticker__word">{{ word | strip }}</span>
            <span class="rw-pw-ticker__dot"></span>
          </span>
        {%- endfor -%}
      </span>
    {%- endfor -%}
  </div>

  {%- if s.copyright_text != blank -%}
    <p class="rw-pw-ticker__copyright">{{ s.copyright_text }}</p>
  {%- endif -%}
</div>

{% stylesheet %}
  .rw-pw-ticker {
    border-top: 1px solid rgba(var(--color-foreground-rgb), 0.16);
    padding-block: 16px;
  }
  .rw-pw-ticker__track {
    display: flex;
    width: max-content;
    overflow: hidden;
    animation: rw-pw-scroll 38s linear infinite;
  }
  .rw-pw-ticker__group {
    display: inline-flex;
    align-items: center;
    gap: 48px;
    padding-inline-end: 48px;
  }
  .rw-pw-ticker__item {
    display: inline-flex;
    align-items: center;
    gap: 48px;
  }
  .rw-pw-ticker__word {
    font-family: var(--font-heading--family);
    font-weight: var(--font-heading--weight);
    text-transform: uppercase;
    font-size: 30px;
    line-height: 1;
    white-space: nowrap;
  }
  .rw-pw-ticker__dot {
    display: inline-block;
    width: 9px;
    height: 9px;
    background: rgb(var(--color-button));
    transform: rotate(45deg);
    flex-shrink: 0;
  }
  .rw-pw-ticker__copyright {
    font-family: var(--font-accent--family);
    font-size: 11px;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    text-align: center;
    color: rgba(var(--color-foreground-rgb), 0.62);
    margin: 16px 0 0;
  }
  @keyframes rw-pw-scroll {
    from { transform: translateX(0); }
    to { transform: translateX(-50%); }
  }
  @media (prefers-reduced-motion: reduce) {
    .rw-pw-ticker__track {
      animation: none;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "RW Password ticker",
  "tag": "div",
  "settings": [
    {
      "type": "text",
      "id": "ticker_text",
      "label": "Ticker words (comma separated)",
      "default": "Opening soon, Chapter 04 incoming, 250 pieces, No restocks, From Eastern Europe, Reborn.Wxrldwide"
    },
    {
      "type": "text",
      "id": "copyright_text",
      "label": "Copyright line",
      "default": "© Reborn Worldwide 2026 — Kraków · Berlin · Lisbon"
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-4"
    }
  ],
  "presets": [
    {
      "name": "RW Password ticker"
    }
  ]
}
{% endschema %}
