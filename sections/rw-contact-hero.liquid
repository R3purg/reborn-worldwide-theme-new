{% liquid
  assign s = section.settings
%}

<section class="rw-contact-hero color-{{ s.color_scheme }}">
  <div class="rw-contact-hero__inner">
    <div class="rw-contact-hero__breadcrumb">
      <a href="{{ routes.root_url }}">HOME</a>
      <span>/</span>
      <span class="rw-contact-hero__current">{{ page.title | default: s.heading | upcase }}</span>
    </div>

    {%- if s.kicker != blank -%}
      <div class="rw-contact-hero__kicker">{{ s.kicker }}</div>
    {%- endif -%}

    <h1 class="rw-contact-hero__title">{{ s.heading }}</h1>

    {%- if s.intro != blank -%}
      <div class="rw-contact-hero__intro">{{ s.intro }}</div>
    {%- endif -%}
  </div>
</section>

{% stylesheet %}
  .rw-contact-hero {
    padding: 48px 24px 0;
  }
  .rw-contact-hero__inner {
    max-width: 1180px;
    margin-inline: auto;
  }
  .rw-contact-hero__breadcrumb {
    font-family: var(--font-accent--family);
    font-size: 11px;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: rgba(var(--color-foreground-rgb), 0.62);
    display: flex;
    gap: 8px;
    margin-bottom: 24px;
  }
  .rw-contact-hero__breadcrumb a {
    text-decoration: none;
    transition: opacity 0.2s ease;
  }
  .rw-contact-hero__breadcrumb a:hover {
    opacity: 0.7;
  }
  .rw-contact-hero__current {
    color: var(--color-foreground);
  }
  .rw-contact-hero__kicker {
    font-family: var(--font-accent--family);
    font-size: 11px;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--color-foreground);
    opacity: 0.7;
    margin-bottom: 16px;
  }
  .rw-contact-hero__title {
    font-family: var(--font-heading--family);
    font-weight: var(--font-heading--weight);
    text-transform: uppercase;
    font-size: clamp(56px, 11vw, 180px);
    line-height: 0.86;
    letter-spacing: -0.01em;
    margin: 0;
    padding-bottom: 0.1em;
  }
  .rw-contact-hero__intro {
    font-size: 20px;
    line-height: 1.5;
    color: rgba(var(--color-foreground-rgb), 0.62);
    max-width: 620px;
    margin-top: 24px;
    text-wrap: pretty;
  }
  .rw-contact-hero__intro p {
    margin: 0;
  }
  @media (max-width: 749px) {
    .rw-contact-hero {
      padding: 32px 16px 0;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "RW Contact hero",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "kicker",
      "label": "Kicker",
      "default": "// SAY SOMETHING"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "GET IN TOUCH"
    },
    {
      "type": "richtext",
      "id": "intro",
      "label": "Intro copy",
      "default": "<p>Orders, returns, wholesale, or just to tell us the last drop went too fast. A real person in one of three cities will read it — usually within a day.</p>"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    }
  ],
  "presets": [
    {
      "name": "RW Contact hero"
    }
  ]
}
{% endschema %}
