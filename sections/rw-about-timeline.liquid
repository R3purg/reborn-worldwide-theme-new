{% liquid
  assign s = section.settings
%}

<section class="rw-about-timeline color-{{ s.color_scheme }}">
  <div class="rw-about-timeline__inner">
    {%- if s.kicker != blank -%}
      <div class="rw-about-timeline__kicker">{{ s.kicker }}</div>
    {%- endif -%}
    <h2 class="rw-about-timeline__heading">{{ s.heading }}</h2>

    {%- if section.blocks.size > 0 -%}
      <div class="rw-about-timeline__list">
        {%- for block in section.blocks -%}
          <div class="rw-about-timeline__row" {{ block.shopify_attributes }}>
            <div class="rw-about-timeline__year">{{ block.settings.year }}</div>
            <div>
              <h3 class="rw-about-timeline__title">{{ block.settings.title }}</h3>
              <p class="rw-about-timeline__body">{{ block.settings.body }}</p>
            </div>
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</section>

{% stylesheet %}
  .rw-about-timeline {
    padding: 88px 24px;
  }
  .rw-about-timeline__inner {
    max-width: 1180px;
    margin-inline: auto;
  }
  .rw-about-timeline__kicker {
    font-family: var(--font-accent--family);
    font-size: 11px;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: rgba(var(--color-foreground-rgb), 0.62);
    margin-bottom: 14px;
  }
  .rw-about-timeline__heading {
    font-family: var(--font-heading--family);
    font-weight: var(--font-heading--weight);
    text-transform: uppercase;
    font-size: clamp(36px, 5vw, 72px);
    line-height: 0.95;
    margin: 0 0 48px;
  }
  .rw-about-timeline__list {
    display: flex;
    flex-direction: column;
  }
  .rw-about-timeline__row {
    display: grid;
    grid-template-columns: 160px 1fr;
    gap: 32px;
    padding: 28px 0;
    border-top: 1px solid var(--color-foreground);
    align-items: start;
  }
  .rw-about-timeline__year {
    font-family: var(--font-heading--family);
    font-weight: var(--font-heading--weight);
    font-size: clamp(32px, 3vw, 52px);
    color: rgb(var(--color-button));
  }
  .rw-about-timeline__title {
    font-size: 22px;
    font-weight: 700;
    margin: 0;
  }
  .rw-about-timeline__body {
    font-size: 16px;
    line-height: 1.6;
    color: rgba(var(--color-foreground-rgb), 0.62);
    margin-top: 10px;
    max-width: 620px;
    text-wrap: pretty;
  }
  @media (max-width: 749px) {
    .rw-about-timeline {
      padding: 56px 16px;
    }
    .rw-about-timeline__row {
      grid-template-columns: 1fr;
      gap: 12px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "RW About timeline",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "kicker",
      "label": "Kicker",
      "default": "// THE SHORT HISTORY"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "How we got here"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    }
  ],
  "blocks": [
    {
      "type": "milestone",
      "name": "Milestone",
      "settings": [
        {
          "type": "text",
          "id": "year",
          "label": "Year",
          "default": "2024"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "The garage"
        },
        {
          "type": "textarea",
          "id": "body",
          "label": "Body text",
          "default": "Two borrowed screens, a kettle, and a refusal to print logos on blanks. Chapter 01 — My Swamp — sells out in a weekend."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "RW About timeline",
      "blocks": [
        { "type": "milestone", "settings": { "year": "2024", "title": "The garage", "body": "Two borrowed screens, a kettle, and a refusal to print logos on blanks. Chapter 01 — My Swamp — sells out in a weekend." } },
        { "type": "milestone", "settings": { "year": "2025", "title": "Three cities", "body": "Berlin showroom opens, Lisbon studio follows. Chapters 02 and 03 evaporate in minutes. The list grows past 40k." } },
        { "type": "milestone", "settings": { "year": "2026", "title": "Vol. 04", "body": "Chapter 04 — Bikini Bling — drops worldwide. Same four people. Same screens. Still no restocks." } }
      ]
    }
  ]
}
{% endschema %}
