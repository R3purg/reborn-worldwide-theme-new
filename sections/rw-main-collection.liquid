{% liquid
  assign s = section.settings
%}

{% paginate collection.products by s.products_per_page %}
<section class="rw-col-main color-{{ s.color_scheme }}">
  <div class="rw-col-main__inner">
    {%- comment %} Sticky filter/sort bar {%- endcomment %}
    <div class="rw-col-main__bar">
      <div class="rw-col-main__bar-inner">
        <div class="rw-col-main__filters">
          <span class="rw-col-main__filter-label">// FILTER</span>

          {%- if collection.all_filters.size > 0 -%}
            {%- for filter in collection.all_filters -%}
              {%- if filter.type == 'list' -%}
                <div class="rw-col-main__filter-drop">
                  <details class="rw-col-main__details">
                    <summary class="rw-col-main__summary">
                      <span>{{ filter.label }}</span>
                      <svg
                        width="11"
                        height="11"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        aria-hidden="true"
                      >
                        <path d="m6 9 6 6 6-6"/>
                      </svg>
                    </summary>
                    <div class="rw-col-main__panel">
                      {%- for option in filter.values -%}
                        <a
                          href="{{ option.url }}"
                          class="rw-col-main__panel-item {% if option.active %}rw-col-main__panel-item--active{% endif %}"
                        >
                          {{ option.label }}
                          {%- if option.count >= 0 %} ({{ option.count }}){% endif -%}
                        </a>
                      {%- endfor -%}
                    </div>
                  </details>
                </div>
              {%- endif -%}
            {%- endfor -%}
          {%- endif -%}
        </div>

        <div class="rw-col-main__sort-wrap">
          <span class="rw-col-main__result-count">{{ collection.products_count }} RESULTS</span>
          <div class="rw-col-main__divider"></div>

          <label class="rw-col-main__sort-label">
            SORT
            <select class="rw-col-main__sort-select" onchange="window.location = this.value;">
              {%- for option in collection.sort_options -%}
                <option
                  value="{{ option.url }}"
                  {% if option.is_active %}
                    selected
                  {% endif %}
                >
                  {{ option.name }}
                </option>
              {%- endfor -%}
            </select>
          </label>
        </div>
      </div>
    </div>

    {%- comment %} Active filter chips {%- endcomment %}
    {%- liquid
      assign has_active_filters = false
      for filter in collection.all_filters
        if filter.active_values.size > 0
          assign has_active_filters = true
        endif
      endfor
    -%}
    {%- if has_active_filters -%}
      <div class="rw-col-main__chips">
        <span class="rw-col-main__chips-label">ACTIVE:</span>
        {%- for filter in collection.all_filters -%}
          {%- for active_value in filter.active_values -%}
            <a href="{{ active_value.url_to_remove }}" class="rw-col-main__chip">
              {{ active_value.label }}
              <svg width="10" height="10" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.2" aria-hidden="true"><path d="m6 6 12 12M6 18 18 6"/></svg>
            </a>
          {%- endfor -%}
        {%- endfor -%}
        <a href="{{ collection.url }}" class="rw-col-main__chip-clear">Clear all</a>
      </div>
    {%- endif -%}

    {%- comment %} Product grid {%- endcomment %}
    <div class="rw-col-main__grid" style="--col-count: {{ s.columns }}">
      {%- if collection.products.size > 0 -%}
        {%- for product in collection.products -%}
          {%- liquid
            assign is_sold_out = false
            unless product.available
              assign is_sold_out = true
            endunless

            assign tag_label = ''
            assign tag_modifier = ''
            if is_sold_out
              assign tag_label = 'SOLD OUT'
              assign tag_modifier = 'rw-col__tag--sold'
            elsif product.tags contains 'new'
              assign tag_label = 'NEW'
              assign tag_modifier = 'rw-col__tag--new'
            elsif product.tags contains 'low-stock'
              assign tag_label = 'LOW STOCK'
            else
              if product.compare_at_price > product.price
                assign discount_pct = product.compare_at_price | minus: product.price | times: 100 | divided_by: product.compare_at_price
                assign tag_label = '-' | append: discount_pct | append: '%'
              endif
            endif

            assign total_stock = 0
            assign tracks_inventory = false
            for v in product.variants
              if v.inventory_management != blank
                assign tracks_inventory = true
                if v.inventory_quantity > 0
                  assign total_stock = total_stock | plus: v.inventory_quantity
                endif
              endif
            endfor

            assign has_one_variant = false
            if product.variants.size == 1 and product.variants.first.title == 'Default Title'
              assign has_one_variant = true
            endif
          -%}

          <div class="rw-col__card">
            <div class="rw-col__card-media">
              {%- if product.featured_image != blank -%}
                <div class="rw-col__card-img-wrap">
                  <a href="{{ product.url }}" aria-label="{{ product.title | escape }}" tabindex="-1">
                    {{
                      product.featured_image
                      | image_url: width: 600
                      | image_tag: loading: 'lazy', class: 'rw-col__card-img', alt: product.featured_image.alt
                      | default: product.title
                    }}
                  </a>
                </div>
              {%- else -%}
                <div class="rw-col__card-img-wrap">
                  <a href="{{ product.url }}" aria-label="{{ product.title | escape }}" tabindex="-1">
                    <div class="rw-col__card-ph">{{ 'product-1' | placeholder_svg_tag: 'rw-col__ph-svg' }}</div>
                  </a>
                </div>
              {%- endif -%}

              {%- if tag_label != blank -%}
                <div class="rw-col__tag {{ tag_modifier }}">{{ tag_label }}</div>
              {%- endif -%}

              {%- unless is_sold_out -%}
                <div class="rw-col__quick-add" aria-hidden="true">
                  <div class="rw-col__qa-inner">
                    {%- unless has_one_variant -%}
                      {%- liquid
                        assign size_option_idx = null
                        for opt in product.options_with_values
                          assign opt_lower = opt.name | downcase
                          if opt_lower == 'size' or opt_lower == 'sizes'
                            assign size_option_idx = forloop.index0
                          endif
                        endfor
                      -%}
                      <div class="rw-col__sizes" role="group" aria-label="Select size">
                        {%- if size_option_idx != null -%}
                          {%- assign size_opt = product.options_with_values[size_option_idx] -%}
                          {%- for size_val in size_opt.values -%}
                            {%- liquid
                              assign size_variant = null
                              for v in product.variants
                                if v.options[size_option_idx] == size_val
                                  if size_variant == null
                                    assign size_variant = v
                                  elsif v.available and size_variant.available == false
                                    assign size_variant = v
                                  endif
                                endif
                              endfor
                            -%}
                            {%- if size_variant != null -%}
                              <button
                                class="rw-col__size-btn"
                                type="button"
                                data-variant-id="{{ size_variant.id }}"
                                {% unless size_variant.available %}
                                  disabled
                                {% endunless %}
                              >
                                {{ size_val }}
                              </button>
                            {%- endif -%}
                          {%- endfor -%}
                        {%- else -%}
                          {%- for variant in product.variants -%}
                            <button
                              class="rw-col__size-btn"
                              type="button"
                              data-variant-id="{{ variant.id }}"
                              {% unless variant.available %}
                                disabled
                              {% endunless %}
                            >
                              {{ variant.option1 }}
                            </button>
                          {%- endfor -%}
                        {%- endif -%}
                      </div>
                    {%- endunless -%}
                    <button
                      class="rw-col__add-btn"
                      type="button"
                      {% if has_one_variant %}
                        data-variant-id="{{ product.variants.first.id }}"
                      {% else %}
                        disabled
                      {% endif %}
                      aria-label="Add {{ product.title | escape }} to cart"
                    >
                      <svg
                        width="11"
                        height="11"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="1.8"
                        aria-hidden="true"
                      >
                        <path d="M12 5v14M5 12h14"/>
                      </svg>
                      Add
                    </button>
                  </div>
                </div>
              {%- endunless -%}
            </div>

            <div class="rw-col__card-info">
              <div class="rw-col__card-text">
                <a href="{{ product.url }}" class="rw-col__card-title">{{ product.title }}</a>
                <div class="rw-col__card-meta">
                  {%- if product.variants.first.sku != blank -%}
                    <span class="rw-col__card-sku">{{ product.variants.first.sku }}</span>
                  {%- endif -%}
                </div>
              </div>
              <div class="rw-col__card-price">
                <div class="rw-col__price">{{ product.price | money }}</div>
                {%- if product.compare_at_price > product.price -%}
                  <div class="rw-col__price-was">{{ product.compare_at_price | money }}</div>
                {%- endif -%}
              </div>
            </div>

            {%- if tracks_inventory and is_sold_out == false -%}
              <div class="rw-col__stock">
                <div class="rw-col__stock-bar">
                  <div
                    class="rw-col__stock-fill{% if total_stock <= 10 %} rw-col__stock-fill--low{% endif %}"
                    style="width: max(8%, min(100%, calc({{ total_stock }} * 1.5%)));"
                  ></div>
                </div>
                <div class="rw-col__stock-text">
                  {%- if total_stock <= 10 -%}
                    ONLY {{ total_stock }} LEFT
                  {%- else -%}
                    {{ total_stock }} IN STOCK
                  {%- endif -%}
                </div>
              </div>
            {%- endif -%}
          </div>
        {%- endfor -%}
      {%- else -%}
        <div class="rw-col__empty">
          <div class="rw-col__empty-heading">Nothing here.</div>
          <div class="rw-col__empty-subline">// TRY LOOSENING YOUR FILTERS</div>
        </div>
      {%- endif -%}
    </div>

    {%- if paginate.pages > 1 -%}
      <div class="rw-col-main__pagination">
        {%- if paginate.previous -%}
          <a href="{{ paginate.previous.url }}" class="rw-col-main__page-btn">PREV</a>
        {%- else -%}
          <span class="rw-col-main__page-btn rw-col-main__page-btn--disabled">PREV</span>
        {%- endif -%}

        {%- for part in paginate.parts -%}
          {%- if part.title == '...' -%}
            <span class="rw-col-main__page-ellipsis">&#8230;</span>
          {%- elsif part.is_link -%}
            <a href="{{ part.url }}" class="rw-col-main__page-btn">{{ part.title }}</a>
          {%- else -%}
            <span class="rw-col-main__page-btn rw-col-main__page-btn--active">{{ part.title }}</span>
          {%- endif -%}
        {%- endfor -%}

        {%- if paginate.next -%}
          <a href="{{ paginate.next.url }}" class="rw-col-main__page-btn">NEXT</a>
        {%- else -%}
          <span class="rw-col-main__page-btn rw-col-main__page-btn--disabled">NEXT</span>
        {%- endif -%}
      </div>
    {%- endif -%}
  </div>
</section>
{% endpaginate %}

{% javascript %}
  (function () {
    document.querySelectorAll('.rw-col-main').forEach(function (section) {
      section.addEventListener('click', function (e) {
        /* size button: select, enable add */
        var sizeBtn = e.target.closest('.rw-col__size-btn');
        if (sizeBtn && !sizeBtn.disabled) {
          var card = sizeBtn.closest('.rw-col__card');
          card.querySelectorAll('.rw-col__size-btn').forEach(function (b) {
            b.classList.remove('is-active');
          });
          sizeBtn.classList.add('is-active');
          var addBtn = card.querySelector('.rw-col__add-btn');
          if (addBtn) {
            addBtn.dataset.variantId = sizeBtn.dataset.variantId;
            addBtn.removeAttribute('disabled');
          }
          return;
        }

        /* add button: cart/add.js */
        var addBtn = e.target.closest('.rw-col__add-btn');
        if (addBtn && addBtn.dataset.variantId && !addBtn.disabled) {
          e.preventDefault();
          var label = addBtn.innerHTML;
          addBtn.disabled = true;
          addBtn.textContent = '...';
          fetch(window.Shopify.routes.root + 'cart/add.js', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
            body: JSON.stringify({ id: parseInt(addBtn.dataset.variantId, 10), quantity: 1 })
          })
            .then(function (r) { return r.json(); })
            .then(function () {
              addBtn.textContent = '+';
              document.dispatchEvent(new CustomEvent('cart:refresh', { bubbles: true }));
              setTimeout(function () { addBtn.innerHTML = label; addBtn.disabled = false; }, 1800);
            })
            .catch(function () {
              addBtn.textContent = '!';
              setTimeout(function () { addBtn.innerHTML = label; addBtn.disabled = false; }, 1800);
            });
        }
      });
    });
  })();
{% endjavascript %}

{% stylesheet %}
  .rw-col-main {
    padding: 0;
  }
  .rw-col-main__inner {
    max-width: 1440px;
    margin-inline: auto;
  }

  /* ── Sticky filter bar ── */
  .rw-col-main__bar {
    position: sticky;
    top: var(--header-height, 60px);
    z-index: 40;
    background: var(--color-background);
    border-bottom: 1px solid rgba(var(--color-foreground-rgb), 0.18);
    padding: 16px 24px;
  }
  .rw-col-main__bar-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 16px;
    flex-wrap: wrap;
  }

  .rw-col-main__filters {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
    align-items: center;
  }
  .rw-col-main__filter-label {
    font-family: var(--font-accent--family);
    font-size: 11px;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: rgba(var(--color-foreground-rgb), 0.62);
    margin-right: 4px;
  }

  .rw-col-main__filter-drop {
    position: relative;
  }
  .rw-col-main__details {
    list-style: none;
  }
  .rw-col-main__details > summary {
    list-style: none;
  }
  .rw-col-main__summary {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 11px 16px;
    border: 1px solid var(--color-foreground);
    border-radius: 999px;
    background: transparent;
    color: var(--color-foreground);
    font-family: var(--font-accent--family);
    font-size: 11px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    cursor: pointer;
    transition: background 0.15s ease, color 0.15s ease;
  }
  .rw-col-main__summary:hover {
    background: rgba(var(--color-foreground-rgb), 0.05);
  }
  .rw-col-main__details[open] .rw-col-main__summary svg {
    transform: rotate(180deg);
  }

  .rw-col-main__panel {
    position: absolute;
    top: calc(100% + 6px);
    left: 0;
    min-width: 200px;
    background: var(--color-background);
    border: 1px solid var(--color-foreground);
    border-radius: 4px;
    box-shadow: 4px 4px 0 var(--color-foreground);
    z-index: 30;
    animation: fadeup 0.15s ease;
    overflow: hidden;
  }
  .rw-col-main__panel-item {
    display: block;
    width: 100%;
    padding: 11px 16px;
    border: 0;
    border-bottom: 1px solid rgba(var(--color-foreground-rgb), 0.18);
    background: transparent;
    color: var(--color-foreground);
    font-family: var(--font-accent--family);
    font-size: 11px;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    text-decoration: none;
    text-align: left;
    cursor: pointer;
    transition: background 0.15s ease;
  }
  .rw-col-main__panel-item:last-child {
    border-bottom: none;
  }
  .rw-col-main__panel-item:hover {
    background: rgba(var(--color-foreground-rgb), 0.08);
  }
  .rw-col-main__panel-item--active {
    background: rgba(var(--color-foreground-rgb), 0.12);
    font-weight: 600;
  }

  .rw-col-main__sort-wrap {
    display: flex;
    gap: 14px;
    align-items: center;
  }
  .rw-col-main__result-count {
    font-family: var(--font-accent--family);
    font-size: 11px;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: rgba(var(--color-foreground-rgb), 0.62);
  }
  .rw-col-main__divider {
    width: 1px;
    height: 20px;
    background: rgba(var(--color-foreground-rgb), 0.18);
  }

  .rw-col-main__sort-label {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-accent--family);
    font-size: 11px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: rgba(var(--color-foreground-rgb), 0.62);
  }
  .rw-col-main__sort-select {
    background: transparent;
    border: 1px solid var(--color-foreground);
    border-radius: 999px;
    padding: 9px 14px;
    font-family: var(--font-accent--family);
    font-size: 11px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-foreground);
    cursor: pointer;
  }

  /* ── Product grid ── */
  .rw-col-main__grid {
    display: grid;
    grid-template-columns: repeat(var(--col-count, 4), 1fr);
    gap: 24px;
    padding: 40px 24px 80px;
  }

  .rw-col__card {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  /* ── Card media (same as rw-shop-floor) ── */
  .rw-col__card-media {
    aspect-ratio: 4 / 5;
    position: relative;
    overflow: hidden;
  }
  .rw-col__card-img-wrap {
    position: absolute;
    inset: 0;
    overflow: hidden;
  }
  .rw-col__card-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.5s cubic-bezier(0.2, 0.7, 0.2, 1);
  }
  .rw-col__card:hover .rw-col__card-img {
    transform: scale(1.03);
  }

  .rw-col__card-ph {
    width: 100%;
    height: 100%;
    background: repeating-linear-gradient(135deg, rgba(var(--color-foreground-rgb), 0.06) 0 14px, transparent 14px 28px),
      var(--color-background);
  }
  .rw-col__ph-svg {
    width: 100%;
    height: 100%;
    display: block;
    opacity: 0.3;
  }

  /* ── Tag badge ── */
  .rw-col__tag {
    position: absolute;
    top: 12px;
    left: 12px;
    padding: 6px 10px;
    background: var(--color-background);
    color: var(--color-foreground);
    border: 1px solid var(--color-foreground);
    font-family: var(--font-accent--family);
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    pointer-events: none;
    z-index: 2;
  }
  .rw-col__tag--new {
    background: rgb(var(--color-button));
    color: rgb(var(--color-button-label));
  }
  .rw-col__tag--sold {
    background: var(--color-foreground);
    color: var(--color-background);
  }

  /* ── Quick-add panel ── */
  .rw-col__quick-add {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    padding: 10px;
    transform: translateY(110%);
    transition: transform 0.35s cubic-bezier(0.2, 0.7, 0.2, 1);
    z-index: 3;
  }
  .rw-col__card:hover .rw-col__quick-add {
    transform: translateY(0);
  }
  .rw-col__qa-inner {
    background: rgba(var(--color-background-rgb), 0.96);
    border: 1px solid var(--color-foreground);
    padding: 10px 12px;
    display: flex;
    align-items: center;
    gap: 8px;
    overflow: hidden;
  }
  .rw-col__sizes {
    display: flex;
    gap: 6px;
    flex: 1;
    min-width: 0;
    overflow-x: auto;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }
  .rw-col__sizes::-webkit-scrollbar {
    display: none;
  }
  .rw-col__size-btn {
    flex-shrink: 0;
    height: 30px;
    min-width: 30px;
    padding: 0 8px;
    border: 1px solid var(--color-foreground);
    background: transparent;
    color: var(--color-foreground);
    font-family: var(--font-accent--family);
    font-size: 11px;
    letter-spacing: 0.04em;
    cursor: pointer;
    transition: background 0.15s ease, color 0.15s ease;
    white-space: nowrap;
  }
  .rw-col__size-btn.is-active {
    background: var(--color-foreground);
    color: var(--color-background);
  }
  .rw-col__size-btn:disabled {
    opacity: 0.35;
    cursor: not-allowed;
  }
  .rw-col__add-btn {
    flex-shrink: 0;
    border: 1px solid var(--color-foreground);
    background: var(--color-foreground);
    color: var(--color-background);
    padding: 8px 14px;
    font-family: var(--font-accent--family);
    font-size: 11px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    white-space: nowrap;
    transition: opacity 0.2s ease;
  }
  .rw-col__add-btn:disabled {
    opacity: 0.45;
    cursor: not-allowed;
  }

  /* ── Card info ── */
  .rw-col__card-info {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 10px;
  }
  .rw-col__card-text {
    flex: 1;
    min-width: 0;
  }
  .rw-col__card-title {
    display: block;
    font-size: 14px;
    font-weight: 600;
    line-height: 1.3;
    color: var(--color-foreground);
    text-decoration: none;
  }
  .rw-col__card-title:hover {
    text-decoration: underline;
  }
  .rw-col__card-meta {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-top: 6px;
    flex-wrap: wrap;
  }
  .rw-col__card-sku {
    font-family: var(--font-accent--family);
    font-size: 11px;
    letter-spacing: 0.04em;
    color: rgba(var(--color-foreground-rgb), 0.62);
  }
  .rw-col__card-price {
    text-align: right;
    flex-shrink: 0;
  }
  .rw-col__price {
    font-size: 14px;
    font-weight: 600;
  }
  .rw-col__price-was {
    font-family: var(--font-accent--family);
    font-size: 11px;
    color: rgba(var(--color-foreground-rgb), 0.62);
    text-decoration: line-through;
    margin-top: 4px;
  }

  /* ── Stock bar ── */
  .rw-col__stock {
    margin-top: -4px;
  }
  .rw-col__stock-bar {
    height: 2px;
    background: rgba(var(--color-foreground-rgb), 0.18);
    overflow: hidden;
  }
  .rw-col__stock-fill {
    height: 100%;
    background: var(--color-foreground);
    transition: width 0.3s ease;
  }
  .rw-col__stock-fill--low {
    background: rgb(var(--color-button));
  }
  .rw-col__stock-text {
    font-family: var(--font-accent--family);
    font-size: 11px;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: rgba(var(--color-foreground-rgb), 0.62);
    margin-top: 6px;
  }

  /* ── Empty state ── */
  .rw-col__empty {
    grid-column: 1 / -1;
    text-align: center;
    padding: 80px 0;
  }
  .rw-col__empty-heading {
    font-family: var(--font-heading--family);
    font-size: 48px;
    font-weight: var(--font-heading--weight);
    text-transform: uppercase;
    color: var(--color-foreground);
    margin: 0;
  }
  .rw-col__empty-subline {
    font-family: var(--font-accent--family);
    font-size: 11px;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: rgba(var(--color-foreground-rgb), 0.62);
    margin-top: 12px;
  }

  /* ── Active chips ── */
  .rw-col-main__chips {
    padding: 0 24px 14px;
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    align-items: center;
  }
  .rw-col-main__chips-label {
    font-family: var(--font-accent--family);
    font-size: 11px;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: rgba(var(--color-foreground-rgb), 0.62);
  }
  .rw-col-main__chip {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 6px 12px;
    border: 1px solid var(--color-foreground);
    border-radius: 999px;
    background: var(--color-background);
    color: var(--color-foreground);
    font-family: var(--font-accent--family);
    font-size: 10px;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    text-decoration: none;
    cursor: pointer;
    transition: background 0.15s ease;
  }
  .rw-col-main__chip:hover {
    background: rgba(var(--color-foreground-rgb), 0.08);
  }
  .rw-col-main__chip-clear {
    background: transparent;
    border: 0;
    font-family: var(--font-accent--family);
    font-size: 11px;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    text-decoration: underline;
    color: rgba(var(--color-foreground-rgb), 0.62);
    cursor: pointer;
    padding: 0;
  }

  /* ── Pagination ── */
  .rw-col-main__pagination {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 8px;
    margin: -64px 0 48px;
    padding: 0 24px;
  }
  .rw-col-main__page-btn {
    min-width: 42px;
    height: 42px;
    padding: 0 12px;
    border: 1px solid var(--color-foreground);
    border-radius: 999px;
    background: transparent;
    color: var(--color-foreground);
    font-family: var(--font-accent--family);
    font-size: 11px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    text-decoration: none;
    cursor: pointer;
    transition: background 0.15s ease, color 0.15s ease;
    line-height: 1;
  }
  .rw-col-main__page-btn:hover:not(:disabled) {
    background: var(--color-foreground);
    color: var(--color-background);
  }
  .rw-col-main__page-btn--active {
    background: var(--color-foreground);
    color: var(--color-background);
  }
  .rw-col-main__page-btn--disabled {
    opacity: 0.35;
    cursor: not-allowed;
  }
  .rw-col-main__page-ellipsis {
    font-family: var(--font-accent--family);
    font-size: 14px;
    color: rgba(var(--color-foreground-rgb), 0.35);
    padding: 0 4px;
  }

  /* ── Responsive ── */
  @media (max-width: 989px) {
    .rw-col-main__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 749px) {
    .rw-col-main {
      padding: 0;
    }
    .rw-col-main__bar {
      padding: 12px 16px;
      top: auto;
      position: relative;
    }
    .rw-col-main__bar-inner {
      flex-direction: column;
      align-items: flex-start;
    }
    .rw-col-main__grid {
      grid-template-columns: 1fr;
      padding: 40px 16px 64px;
      gap: 16px;
    }
    .rw-col-main__sort-wrap {
      display: none;
    }
  }

  @keyframes fadeup {
    from {
      opacity: 0;
      transform: translateY(14px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "RW Collection Main",
  "tag": "section",
  "enabled_on": {
    "templates": ["collection"]
  },
  "settings": [
    {
      "type": "select",
      "id": "columns",
      "label": "Columns",
      "options": [
        { "value": "3", "label": "3" },
        { "value": "4", "label": "4" }
      ],
      "default": "4"
    },
    {
      "type": "range",
      "id": "products_per_page",
      "label": "Products per page",
      "min": 8,
      "max": 36,
      "step": 4,
      "default": 24
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    }
  ],
  "presets": [
    {
      "name": "RW Collection Main"
    }
  ]
}
{% endschema %}
