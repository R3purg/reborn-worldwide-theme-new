{% liquid
  assign s = section.settings
%}

<section class="rw-about-team color-{{ s.color_scheme }}">
  <div class="rw-about-team__inner">
    <div class="rw-about-team__header">
      <h2 class="rw-about-team__heading">{{ s.heading }}</h2>
      {%- if s.kicker != blank -%}
        <span class="rw-about-team__kicker">{{ s.kicker }}</span>
      {%- endif -%}
    </div>

    {%- if section.blocks.size > 0 -%}
      <div class="rw-about-team__grid">
        {%- for block in section.blocks -%}
          {%- liquid
            assign portrait_alt = block.settings.name | append: ' — ' | append: block.settings.role
          -%}
          <div class="rw-about-team__card" {{ block.shopify_attributes }}>
            <div class="rw-about-team__media">
              {%- if block.settings.image != blank -%}
                {{
                  block.settings.image
                  | image_url: width: 500
                  | image_tag: loading: 'lazy', class: 'rw-about-team__img', alt: portrait_alt
                  | default: ''
                }}
              {%- else -%}
                <div class="rw-about-team__ph"></div>
              {%- endif -%}
            </div>
            <div class="rw-about-team__meta">
              <div class="rw-about-team__name">{{ block.settings.name }}</div>
              <div class="rw-about-team__role">{{ block.settings.role }} · {{ block.settings.city }}</div>
            </div>
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</section>

{% stylesheet %}
  .rw-about-team {
    padding: 0 24px 88px;
  }
  .rw-about-team__inner {
    max-width: 1440px;
    margin-inline: auto;
  }
  .rw-about-team__header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    flex-wrap: wrap;
    gap: 16px;
    margin-bottom: 32px;
  }
  .rw-about-team__heading {
    font-family: var(--font-heading--family);
    font-weight: var(--font-heading--weight);
    text-transform: uppercase;
    font-size: clamp(32px, 5vw, 68px);
    line-height: 0.95;
    margin: 0;
  }
  .rw-about-team__kicker {
    font-family: var(--font-accent--family);
    font-size: 11px;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: rgba(var(--color-foreground-rgb), 0.62);
  }
  .rw-about-team__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
  }
  .rw-about-team__media {
    aspect-ratio: 4 / 5;
    overflow: hidden;
    transition: transform 0.35s cubic-bezier(0.2, 0.7, 0.2, 1);
  }
  .rw-about-team__media:hover {
    transform: translateY(-4px);
  }
  .rw-about-team__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .rw-about-team__ph {
    width: 100%;
    height: 100%;
    background: repeating-linear-gradient(135deg, rgba(var(--color-foreground-rgb), 0.06) 0 14px, transparent 14px 28px),
      var(--color-background);
    border: 1px solid rgba(var(--color-foreground-rgb), 0.18);
  }
  .rw-about-team__meta {
    margin-top: 14px;
  }
  .rw-about-team__name {
    font-size: 18px;
    font-weight: 700;
  }
  .rw-about-team__role {
    font-family: var(--font-accent--family);
    font-size: 11px;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: rgba(var(--color-foreground-rgb), 0.62);
    margin-top: 6px;
  }
  @media (max-width: 989px) {
    .rw-about-team__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 749px) {
    .rw-about-team {
      padding: 0 16px 56px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "RW About team",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "The four of us"
    },
    {
      "type": "text",
      "id": "kicker",
      "label": "Kicker",
      "default": "// THE WHOLE COMPANY"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    }
  ],
  "blocks": [
    {
      "type": "member",
      "name": "Team member",
      "limit": 6,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Portrait"
        },
        {
          "type": "text",
          "id": "name",
          "label": "Name",
          "default": "Marek"
        },
        {
          "type": "text",
          "id": "role",
          "label": "Role",
          "default": "Print + production"
        },
        {
          "type": "text",
          "id": "city",
          "label": "City",
          "default": "Kraków"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "RW About team",
      "blocks": [
        { "type": "member", "settings": { "name": "Marek", "role": "Print + production", "city": "Kraków" } },
        { "type": "member", "settings": { "name": "Lena", "role": "Design + story", "city": "Berlin" } },
        { "type": "member", "settings": { "name": "Tomas", "role": "Photography", "city": "Lisbon" } },
        { "type": "member", "settings": { "name": "Ola", "role": "Everything else", "city": "Kraków" } }
      ]
    }
  ]
}
{% endschema %}
