{% liquid
  assign s = section.settings
%}

<section class="rw-pw-hero color-{{ s.color_scheme }}" data-section-id="{{ section.id }}">
  <div class="rw-pw-hero__topbar">
    <span class="rw-pw-hero__eyebrow">// {{ s.eyebrow }}</span>
    <button type="button" class="rw-pw-hero__staff-btn" on:click="#password-form/showDialog">
      <span class="svg-wrapper svg-wrapper--small" aria-hidden="true">
        <svg viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg" focusable="false">
          {%- render 'icon', icon: 'lock' -%}
        </svg>
      </span>
      {{ 'actions.enter_using_password' | t }}
    </button>
  </div>

  <div class="rw-pw-hero__main{% unless s.show_image %} rw-pw-hero__main--full{% endunless %}">
    <div class="rw-pw-hero__content">
      <p class="rw-pw-hero__meta">{{ s.meta_line }}</p>

      <h1 class="rw-pw-hero__title">
        {{ s.heading_line_1 }}<br>
        <span class="rw-pw-hero__title-accent">// {{ s.heading_line_2 }}</span>
      </h1>

      <p class="rw-pw-hero__intro">{{ s.intro_text }}</p>

      {%- if s.show_countdown -%}
        <div
          class="rw-pw-hero__countdown"
          id="rw-pw-cd-{{ section.id }}"
          data-target="{{ s.countdown_date }}"
        >
          <p class="rw-pw-hero__cd-label">// {{ s.countdown_label }}</p>
          <div class="rw-pw-hero__cd-grid">
            <div class="rw-pw-hero__cd-unit">
              <span class="rw-pw-hero__cd-num" data-unit="days">00</span>
              <span class="rw-pw-hero__cd-lbl">Days</span>
            </div>
            <div class="rw-pw-hero__cd-unit">
              <span class="rw-pw-hero__cd-num" data-unit="hrs">00</span>
              <span class="rw-pw-hero__cd-lbl">Hrs</span>
            </div>
            <div class="rw-pw-hero__cd-unit">
              <span class="rw-pw-hero__cd-num" data-unit="min">00</span>
              <span class="rw-pw-hero__cd-lbl">Min</span>
            </div>
            <div class="rw-pw-hero__cd-unit">
              <span class="rw-pw-hero__cd-num" data-unit="sec">00</span>
              <span class="rw-pw-hero__cd-lbl">Sec</span>
            </div>
          </div>
        </div>
      {%- endif -%}

      <div class="rw-pw-hero__newsletter">
        <p class="rw-pw-hero__nl-label">// {{ s.newsletter_label }}</p>

        {%- form 'customer', id: 'rw-pw-newsletter-{{ section.id }}', class: 'rw-pw-hero__nl-form' -%}
          <input type="hidden" name="contact[tags]" value="newsletter, opening-soon">

          {%- if form.posted_successfully? -%}
            <div class="rw-pw-hero__nl-success">
              <span class="rw-pw-hero__nl-dot" aria-hidden="true"></span>
              <span>{{ s.newsletter_success }}</span>
            </div>
          {%- else -%}
            <div class="rw-pw-hero__nl-field">
              <label for="rw-pw-nl-{{ section.id }}" class="visually-hidden">Email address</label>
              <input
                type="email"
                name="contact[email]"
                id="rw-pw-nl-{{ section.id }}"
                class="rw-pw-hero__nl-input"
                placeholder="{{ s.newsletter_placeholder }}"
                autocomplete="email"
                required
              >
              <button type="submit" class="rw-pw-hero__nl-submit">{{ s.newsletter_submit_label }} →</button>
            </div>
            {%- if form.errors -%}
              <p class="rw-pw-hero__nl-error" role="alert">{{ form.errors | default_errors }}</p>
            {%- endif -%}
          {%- endif -%}
        {%- endform -%}
      </div>

      {%- if s.show_social -%}
        <div class="rw-pw-hero__social" aria-label="Social">
          {%- if s.social_instagram != blank -%}
            <a href="{{ s.social_instagram }}" class="rw-pw-hero__social-link">Instagram</a>
          {%- endif -%}
          {%- if s.social_tiktok != blank -%}
            <a href="{{ s.social_tiktok }}" class="rw-pw-hero__social-link">TikTok</a>
          {%- endif -%}
          {%- if s.social_discord != blank -%}
            <a href="{{ s.social_discord }}" class="rw-pw-hero__social-link">Discord</a>
          {%- endif -%}
        </div>
      {%- endif -%}
    </div>

    {%- if s.show_image -%}
      <div class="rw-pw-hero__media">
        {%- if s.image != blank -%}
          {{
            s.image
            | image_url: width: 1200
            | image_tag: loading: 'eager', preload: true, class: 'rw-pw-hero__img', alt: s.image.alt
            | default: 'Reborn Worldwide — opening soon'
          }}
        {%- else -%}
          <div class="rw-pw-hero__media-ph">
            {{ 'lifestyle-2' | placeholder_svg_tag: 'rw-pw-hero__ph-svg' }}
          </div>
        {%- endif -%}

        {%- if s.show_sticker -%}
          <div class="rw-pw-hero__sticker" aria-hidden="true">
            <p class="rw-pw-hero__sticker-main">{{ s.sticker_text }}</p>
            {%- if s.sticker_sub != blank -%}
              <p class="rw-pw-hero__sticker-sub">{{ s.sticker_sub }}</p>
            {%- endif -%}
          </div>
        {%- endif -%}
      </div>
    {%- endif -%}
  </div>
</section>

{% stylesheet %}
  .rw-pw-hero {
    display: flex;
    flex-direction: column;
    min-height: 100svh;
  }
  /* Top bar */
  .rw-pw-hero__topbar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 16px;
    padding: 20px 24px;
    border-bottom: 1px solid rgba(var(--color-foreground-rgb), 0.16);
  }
  .rw-pw-hero__eyebrow {
    font-family: var(--font-accent--family);
    font-size: 11px;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: rgba(var(--color-foreground-rgb), 0.62);
  }
  .rw-pw-hero__staff-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: transparent;
    border: 1px solid rgba(var(--color-foreground-rgb), 0.16);
    border-radius: 999px;
    padding: 8px 14px;
    color: var(--color-foreground);
    font-family: var(--font-accent--family);
    font-size: 11px;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    cursor: pointer;
    transition: border-color 0.2s ease;
  }
  .rw-pw-hero__staff-btn:hover {
    border-color: var(--color-foreground);
  }
  .rw-pw-hero__staff-btn svg {
    width: 13px;
    height: 13px;
    fill: currentColor;
  }
  /* Main split */
  .rw-pw-hero__main {
    flex: 1;
    display: grid;
    grid-template-columns: 1.15fr 0.85fr;
    max-width: 1440px;
    width: 100%;
    margin-inline: auto;
  }
  .rw-pw-hero__main--full {
    grid-template-columns: 1fr;
  }
  /* Content column */
  .rw-pw-hero__content {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: clamp(32px, 6vw, 80px) 24px;
  }
  .rw-pw-hero__meta {
    font-family: var(--font-accent--family);
    font-size: 11px;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: rgba(var(--color-foreground-rgb), 0.62);
    margin: 0 0 18px;
  }
  .rw-pw-hero__title {
    font-family: var(--font-heading--family);
    font-weight: var(--font-heading--weight);
    text-transform: uppercase;
    font-size: clamp(56px, 9vw, 150px);
    line-height: 0.9;
    letter-spacing: -0.01em;
    margin: 0;
    padding-bottom: 0.12em;
  }
  .rw-pw-hero__title-accent {
    color: rgb(var(--color-button));
  }
  .rw-pw-hero__intro {
    font-size: clamp(17px, 1.6vw, 21px);
    line-height: 1.5;
    max-width: 480px;
    margin: 40px 0 0;
    font-weight: 500;
  }
  /* Countdown */
  .rw-pw-hero__countdown {
    margin-top: 36px;
  }
  .rw-pw-hero__cd-label {
    font-family: var(--font-accent--family);
    font-size: 11px;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: rgba(var(--color-foreground-rgb), 0.62);
    margin: 0 0 14px;
  }
  .rw-pw-hero__cd-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 10px;
  }
  .rw-pw-hero__cd-unit {
    display: flex;
    flex-direction: column;
    align-items: center;
    border: 1px solid rgba(var(--color-foreground-rgb), 0.16);
    padding: 16px 14px;
    text-align: center;
  }
  .rw-pw-hero__cd-num {
    font-family: var(--font-heading--family);
    font-weight: var(--font-heading--weight);
    text-transform: uppercase;
    font-size: clamp(36px, 5vw, 64px);
    line-height: 1;
  }
  .rw-pw-hero__cd-lbl {
    font-family: var(--font-accent--family);
    font-size: 10px;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: rgba(var(--color-foreground-rgb), 0.62);
    margin-top: 8px;
  }
  /* Newsletter */
  .rw-pw-hero__newsletter {
    margin-top: 36px;
    max-width: 520px;
  }
  .rw-pw-hero__nl-label {
    font-family: var(--font-accent--family);
    font-size: 11px;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: rgba(var(--color-foreground-rgb), 0.62);
    margin: 0 0 12px;
  }
  .rw-pw-hero__nl-field {
    display: flex;
    border: 1px solid var(--color-foreground);
    border-radius: 999px;
    overflow: hidden;
  }
  .rw-pw-hero__nl-input {
    flex: 1;
    min-width: 0;
    background: transparent;
    border: 0;
    outline: none;
    padding: 16px 20px;
    color: var(--color-foreground);
    font-family: var(--font-accent--family);
    font-size: 12px;
    letter-spacing: 0.04em;
  }
  .rw-pw-hero__nl-input::placeholder {
    color: rgba(var(--color-foreground-rgb), 0.5);
  }
  .rw-pw-hero__nl-submit {
    flex-shrink: 0;
    background: rgb(var(--color-button));
    color: rgb(var(--color-button-label));
    border: 0;
    padding: 0 24px;
    font-family: var(--font-accent--family);
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    transition: filter 0.2s ease;
  }
  .rw-pw-hero__nl-submit:hover {
    filter: brightness(1.1);
  }
  .rw-pw-hero__nl-success {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    padding: 16px 22px;
    border: 1px solid rgb(var(--color-button));
    border-radius: 999px;
    font-family: var(--font-accent--family);
    font-size: 11px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }
  .rw-pw-hero__nl-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: rgb(var(--color-button));
    flex-shrink: 0;
  }
  .rw-pw-hero__nl-error {
    font-family: var(--font-accent--family);
    font-size: 11px;
    letter-spacing: 0.04em;
    color: rgb(var(--color-button));
    margin: 10px 0 0;
  }
  /* Social */
  .rw-pw-hero__social {
    display: flex;
    flex-wrap: wrap;
    gap: 18px;
    margin-top: 36px;
  }
  .rw-pw-hero__social-link {
    font-family: var(--font-accent--family);
    font-size: 11px;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: rgba(var(--color-foreground-rgb), 0.62);
    border-bottom: 1px solid rgba(var(--color-foreground-rgb), 0.16);
    padding-bottom: 4px;
    text-decoration: none;
    transition: color 0.2s ease, border-color 0.2s ease;
  }
  .rw-pw-hero__social-link:hover {
    color: var(--color-foreground);
    border-color: var(--color-foreground);
  }
  /* Media */
  .rw-pw-hero__media {
    position: relative;
    border-left: 1px solid rgba(var(--color-foreground-rgb), 0.16);
    min-height: 360px;
  }
  .rw-pw-hero__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .rw-pw-hero__media-ph {
    position: absolute;
    inset: 0;
    background: repeating-linear-gradient(135deg, rgba(var(--color-foreground-rgb), 0.06) 0 14px, transparent 14px 28px),
      var(--color-background);
  }
  .rw-pw-hero__ph-svg {
    width: 100%;
    height: 100%;
    display: block;
  }
  /* Sticker */
  .rw-pw-hero__sticker {
    position: absolute;
    top: 8%;
    right: 8%;
    background: rgb(var(--color-button));
    color: rgb(var(--color-button-label));
    padding: 12px 16px;
    border: 1px solid var(--color-foreground);
    border-radius: 4px;
    box-shadow: 3px 3px 0 var(--color-foreground);
    transform: rotate(-7deg);
    cursor: default;
    z-index: 2;
  }
  .rw-pw-hero__sticker:hover {
    animation: rw-pw-wobble 0.6s ease-in-out infinite;
  }
  @keyframes rw-pw-wobble {
    0% { transform: rotate(-7deg); }
    50% { transform: rotate(4deg); }
    100% { transform: rotate(-7deg); }
  }
  .rw-pw-hero__sticker-main {
    font-family: var(--font-accent--family);
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    margin: 0;
  }
  .rw-pw-hero__sticker-sub {
    font-family: var(--font-accent--family);
    font-size: 9px;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    opacity: 0.8;
    margin: 2px 0 0;
  }
  /* Mobile */
  @media (max-width: 989px) {
    .rw-pw-hero__main,
    .rw-pw-hero__main--full {
      grid-template-columns: 1fr;
    }
    .rw-pw-hero__media {
      border-left: 0;
      border-top: 1px solid rgba(var(--color-foreground-rgb), 0.16);
      min-height: 280px;
    }
  }
  @media (max-width: 749px) {
    .rw-pw-hero__topbar {
      padding: 16px;
    }
    .rw-pw-hero__content {
      padding: 32px 16px;
    }
    .rw-pw-hero__cd-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
    .rw-pw-hero__nl-field {
      flex-direction: column;
      border-radius: 4px;
    }
    .rw-pw-hero__nl-input {
      border-bottom: 1px solid rgba(var(--color-foreground-rgb), 0.16);
    }
    .rw-pw-hero__nl-submit {
      padding: 16px 22px;
      justify-content: center;
    }
  }
{% endstylesheet %}

{% javascript %}
  (function () {
    function pad(n) {
      return String(n).padStart(2, '0');
    }

    function initCountdown(el) {
      var target = Date.parse(el.dataset.target);
      if (isNaN(target)) return;

      function tick() {
        var diff = Math.max(0, target - Date.now());
        var map = {
          days: Math.floor(diff / 86400000),
          hrs: Math.floor(diff / 3600000) % 24,
          min: Math.floor(diff / 60000) % 60,
          sec: Math.floor(diff / 1000) % 60
        };
        Object.keys(map).forEach(function (key) {
          var node = el.querySelector('[data-unit="' + key + '"]');
          if (node) node.textContent = pad(map[key]);
        });
        if (diff > 0) setTimeout(tick, 1000);
      }
      tick();
    }

    document.querySelectorAll('.rw-pw-hero__countdown').forEach(initCountdown);
  })();
{% endjavascript %}

