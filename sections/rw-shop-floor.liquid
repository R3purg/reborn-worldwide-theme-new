{% liquid
  assign s = section.settings
  if s.collection != blank
    assign shop_col = s.collection
  else
    assign shop_col = collections.all
  endif
%}

<section class="rw-shop color-{{ s.color_scheme }}" id="shop">
  <div class="rw-shop__inner">
    <div class="rw-shop__header">
      <div>
        {%- if s.kicker != blank -%}
          <div class="rw-shop__kicker">{{ s.kicker }}</div>
        {%- endif -%}
        <h2 class="rw-shop__heading">{{ s.heading }}</h2>
      </div>
      <div class="rw-shop__filters" role="group" aria-label="Filter by product type">
        <button class="rw-shop__filter is-active" data-filter="all" type="button">All</button>
        <button class="rw-shop__filter" data-filter="tops" type="button">Tops</button>
        <button class="rw-shop__filter" data-filter="bottoms" type="button">Bottoms</button>
        <button class="rw-shop__filter" data-filter="accessories" type="button">Accessories</button>
      </div>
    </div>

    <div class="rw-shop__grid" data-grid="{{ section.id }}">
      {%- for product in shop_col.products limit: s.max_products -%}
        {%- liquid
          assign is_sold_out = false
          unless product.available
            assign is_sold_out = true
          endunless

          assign tag_label = ''
          assign tag_modifier = ''
          if is_sold_out
            assign tag_label = 'SOLD OUT'
            assign tag_modifier = 'rw-shop__tag--sold'
          elsif product.tags contains 'new'
            assign tag_label = 'NEW'
            assign tag_modifier = 'rw-shop__tag--new'
          elsif product.tags contains 'low-stock'
            assign tag_label = 'LOW STOCK'
          else
            if product.compare_at_price > product.price
              assign discount_pct = product.compare_at_price | minus: product.price | times: 100 | divided_by: product.compare_at_price
              assign tag_label = '-' | append: discount_pct | append: '%'
            endif
          endif

          assign total_stock = 0
          assign tracks_inventory = false
          for v in product.variants
            if v.inventory_management != blank
              assign tracks_inventory = true
              if v.inventory_quantity > 0
                assign total_stock = total_stock | plus: v.inventory_quantity
              endif
            endif
          endfor

          assign has_one_variant = false
          if product.variants.size == 1 and product.variants.first.title == 'Default Title'
            assign has_one_variant = true
          endif
        -%}

        <div
          class="rw-shop__card"
          data-type="{{ product.type | downcase }}"
        >
          <div class="rw-shop__card-media">
            {%- if product.featured_image != blank -%}
              <div class="rw-shop__card-img-wrap">
                <a href="{{ product.url }}" aria-label="{{ product.title | escape }}" tabindex="-1">
                  {{
                    product.featured_image
                    | image_url: width: 600
                    | image_tag: loading: 'lazy', class: 'rw-shop__card-img', alt: product.featured_image.alt
                    | default: product.title
                  }}
                </a>
              </div>
            {%- else -%}
              <div class="rw-shop__card-img-wrap">
                <a
                  href="{{ product.url }}"
                  class="rw-shop__card-ph-link"
                  aria-label="{{ product.title | escape }}"
                  tabindex="-1"
                >
                  <div class="rw-shop__card-ph">{{ 'product-1' | placeholder_svg_tag: 'rw-shop__ph-svg' }}</div>
                </a>
              </div>
            {%- endif -%}

            {%- if tag_label != blank -%}
              <div class="rw-shop__tag {{ tag_modifier }}">{{ tag_label }}</div>
            {%- endif -%}

            {%- unless is_sold_out -%}
              <div class="rw-shop__quick-add" aria-hidden="true">
                <div class="rw-shop__qa-inner">
                  {%- unless has_one_variant -%}
                    {%- liquid
                      assign size_option_idx = null
                      for opt in product.options_with_values
                        assign opt_lower = opt.name | downcase
                        if opt_lower == 'size' or opt_lower == 'sizes'
                          assign size_option_idx = forloop.index0
                        endif
                      endfor
                    -%}
                    <div class="rw-shop__sizes" role="group" aria-label="Select size">
                      {%- if size_option_idx != null -%}
                        {%- assign size_opt = product.options_with_values[size_option_idx] -%}
                        {%- for size_val in size_opt.values -%}
                          {%- liquid
                            assign size_variant = null
                            for v in product.variants
                              if v.options[size_option_idx] == size_val
                                if size_variant == null
                                  assign size_variant = v
                                elsif v.available and size_variant.available == false
                                  assign size_variant = v
                                endif
                              endif
                            endfor
                          -%}
                          {%- if size_variant != null -%}
                            <button
                              class="rw-shop__size-btn"
                              type="button"
                              data-variant-id="{{ size_variant.id }}"
                              {% unless size_variant.available %}
                                disabled
                              {% endunless %}
                            >
                              {{ size_val }}
                            </button>
                          {%- endif -%}
                        {%- endfor -%}
                      {%- else -%}
                        {%- for variant in product.variants -%}
                          <button
                            class="rw-shop__size-btn"
                            type="button"
                            data-variant-id="{{ variant.id }}"
                            {% unless variant.available %}
                              disabled
                            {% endunless %}
                          >
                            {{ variant.option1 }}
                          </button>
                        {%- endfor -%}
                      {%- endif -%}
                    </div>
                  {%- endunless -%}
                  <button
                    class="rw-shop__add-btn"
                    type="button"
                    {% if has_one_variant %}
                      data-variant-id="{{ product.variants.first.id }}"
                    {% else %}
                      disabled
                    {% endif %}
                    aria-label="Add {{ product.title | escape }} to cart"
                  >
                    <svg
                      width="11"
                      height="11"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="1.8"
                      aria-hidden="true"
                    >
                      <path d="M12 5v14M5 12h14"/>
                    </svg>
                    Add
                  </button>
                </div>
              </div>
            {%- endunless -%}
          </div>

          <div class="rw-shop__card-info">
            <div class="rw-shop__card-text">
              <a href="{{ product.url }}" class="rw-shop__card-title">{{ product.title }}</a>
              <div class="rw-shop__card-meta">
                {%- if product.variants.first.sku != blank -%}
                  <span class="rw-shop__card-sku">{{ product.variants.first.sku }}</span>
                {%- endif -%}
                {%- if product.metafields.custom.swatch_colors != blank -%}
                  <span class="rw-shop__swatches" aria-hidden="true">
                    {%- assign swatch_list = product.metafields.custom.swatch_colors | split: ',' -%}
                    {%- for sw in swatch_list -%}
                      <span class="rw-shop__swatch" style="background: {{ sw | strip }};"></span>
                    {%- endfor -%}
                  </span>
                {%- endif -%}
              </div>
            </div>
            <div class="rw-shop__card-price">
              <div class="rw-shop__price">{{ product.price | money }}</div>
              {%- if product.compare_at_price > product.price -%}
                <div class="rw-shop__price-was">{{ product.compare_at_price | money }}</div>
              {%- endif -%}
            </div>
          </div>

          {%- if tracks_inventory and is_sold_out == false -%}
            <div class="rw-shop__stock">
              <div class="rw-shop__stock-bar">
                <div
                  class="rw-shop__stock-fill{% if total_stock <= 10 %} rw-shop__stock-fill--low{% endif %}"
                  style="width: max(8%, min(100%, calc({{ total_stock }} * 1.5%)));"
                ></div>
              </div>
              <div class="rw-shop__stock-text">
                {%- if total_stock <= 10 -%}
                  ONLY {{ total_stock }} LEFT
                {%- else -%}
                  {{ total_stock }} IN STOCK
                {%- endif -%}
              </div>
            </div>
          {%- endif -%}
        </div>
      {%- else -%}
        <p class="rw-shop__empty">No products found in this collection.</p>
      {%- endfor -%}
    </div>

    {%- if s.cta_label != blank -%}
      <div class="rw-shop__footer">
        <a href="{{ s.cta_url | default: shop_col.url | default: '/collections/all' }}" class="rw-shop__view-all">
          {{ s.cta_label }} →
        </a>
      </div>
    {%- endif -%}
  </div>
</section>

{% stylesheet %}
  .rw-shop {
    padding: 96px 24px;
  }
  .rw-shop__inner {
    max-width: 1440px;
    margin-inline: auto;
  }

  /* ── Header ── */
  .rw-shop__header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    flex-wrap: wrap;
    gap: 16px;
    margin-bottom: 32px;
  }
  .rw-shop__kicker {
    font-family: var(--font-accent--family);
    font-size: 11px;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: rgba(var(--color-foreground-rgb), 0.62);
    margin-bottom: 10px;
  }
  .rw-shop__heading {
    font-family: var(--font-heading--family);
    font-weight: var(--font-heading--weight);
    text-transform: uppercase;
    font-size: clamp(40px, 6vw, 84px);
    line-height: 0.86;
    margin: 0;
  }

  /* ── Filter pills ── */
  .rw-shop__filters {
    display: flex;
    gap: 4px;
    padding: 4px;
    border: 1px solid var(--color-foreground);
    border-radius: 999px;
    flex-shrink: 0;
  }
  .rw-shop__filter {
    padding: 8px 16px;
    border-radius: 999px;
    border: 0;
    background: transparent;
    color: var(--color-foreground);
    font-family: var(--font-accent--family);
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    cursor: pointer;
    transition: background 0.2s ease, color 0.2s ease;
    line-height: 1;
  }
  .rw-shop__filter.is-active {
    background: var(--color-foreground);
    color: var(--color-background);
  }
  .rw-shop__filter:not(.is-active):hover {
    background: rgba(var(--color-foreground-rgb), 0.08);
  }

  /* ── Product grid ── */
  .rw-shop__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
  }
  .rw-shop__card {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .rw-shop__card[hidden] {
    display: none;
  }

  /* ── Card media ── */
  .rw-shop__card-media {
    aspect-ratio: 4 / 5;
    position: relative;
    overflow: hidden;
  }
  .rw-shop__card-img-wrap {
    position: absolute;
    inset: 0;
    overflow: hidden;
  }
  .rw-shop__card-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.5s cubic-bezier(0.2, 0.7, 0.2, 1);
  }
  .rw-shop__card:hover .rw-shop__card-img {
    transform: scale(1.03);
  }
  .rw-shop__card-ph-link {
    display: block;
    width: 100%;
    height: 100%;
  }
  .rw-shop__card-ph {
    width: 100%;
    height: 100%;
    background: repeating-linear-gradient(135deg, rgba(var(--color-foreground-rgb), 0.06) 0 14px, transparent 14px 28px),
      var(--color-background);
    border: 1px solid rgba(var(--color-foreground-rgb), 0.18);
  }
  .rw-shop__ph-svg {
    width: 100%;
    height: 100%;
    display: block;
    opacity: 0.3;
  }

  /* ── Tag badge ── */
  .rw-shop__tag {
    position: absolute;
    top: 12px;
    left: 12px;
    padding: 6px 10px;
    background: var(--color-background);
    color: var(--color-foreground);
    border: 1px solid var(--color-foreground);
    font-family: var(--font-accent--family);
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    pointer-events: none;
    z-index: 2;
  }
  .rw-shop__tag--new {
    background: rgb(var(--color-button));
    color: rgb(var(--color-button-label));
    border-color: var(--color-foreground);
  }
  .rw-shop__tag--sold {
    background: var(--color-foreground);
    color: var(--color-background);
  }

  /* ── Quick-add panel ── */
  .rw-shop__quick-add {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    padding: 10px;
    transform: translateY(110%);
    transition: transform 0.35s cubic-bezier(0.2, 0.7, 0.2, 1);
    z-index: 3;
  }
  .rw-shop__card:hover .rw-shop__quick-add {
    transform: translateY(0);
  }
  .rw-shop__qa-inner {
    background: rgba(var(--color-background-rgb), 0.96);
    border: 1px solid var(--color-foreground);
    padding: 10px 12px;
    display: flex;
    align-items: center;
    gap: 8px;
    overflow: hidden;
  }
  .rw-shop__sizes {
    display: flex;
    gap: 6px;
    flex: 1;
    min-width: 0;
    overflow-x: auto;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }
  .rw-shop__sizes::-webkit-scrollbar {
    display: none;
  }
  .rw-shop__size-btn {
    flex-shrink: 0;
    height: 30px;
    min-width: 30px;
    padding: 0 8px;
    border: 1px solid var(--color-foreground);
    background: transparent;
    color: var(--color-foreground);
    font-family: var(--font-accent--family);
    font-size: 11px;
    letter-spacing: 0.04em;
    cursor: pointer;
    transition: background 0.15s ease, color 0.15s ease;
    white-space: nowrap;
  }
  .rw-shop__size-btn.is-active {
    background: var(--color-foreground);
    color: var(--color-background);
  }
  .rw-shop__size-btn:disabled {
    opacity: 0.35;
    cursor: not-allowed;
  }
  .rw-shop__add-btn {
    border: 1px solid var(--color-foreground);
    background: var(--color-foreground);
    color: var(--color-background);
    padding: 8px 14px;
    font-family: var(--font-accent--family);
    font-size: 11px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    white-space: nowrap;
    transition: opacity 0.2s ease;
    flex-shrink: 0;
  }
  .rw-shop__add-btn:disabled {
    opacity: 0.45;
    cursor: not-allowed;
  }

  /* ── Card info ── */
  .rw-shop__card-info {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 10px;
  }
  .rw-shop__card-text {
    flex: 1;
    min-width: 0;
  }
  .rw-shop__card-title {
    display: block;
    font-size: 14px;
    font-weight: 600;
    line-height: 1.3;
    color: var(--color-foreground);
    text-decoration: none;
  }
  .rw-shop__card-title:hover {
    text-decoration: underline;
  }
  .rw-shop__card-meta {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-top: 6px;
    flex-wrap: wrap;
  }
  .rw-shop__card-sku {
    font-family: var(--font-accent--family);
    font-size: 11px;
    letter-spacing: 0.04em;
    color: rgba(var(--color-foreground-rgb), 0.62);
  }
  .rw-shop__swatches {
    display: inline-flex;
    gap: 4px;
  }
  .rw-shop__swatch {
    display: inline-block;
    width: 10px;
    height: 10px;
    border: 1px solid var(--color-foreground);
    flex-shrink: 0;
  }
  .rw-shop__card-price {
    text-align: right;
    flex-shrink: 0;
  }
  .rw-shop__price {
    font-size: 14px;
    font-weight: 600;
  }
  .rw-shop__price-was {
    font-family: var(--font-accent--family);
    font-size: 11px;
    color: rgba(var(--color-foreground-rgb), 0.62);
    text-decoration: line-through;
    margin-top: 4px;
  }

  /* ── Stock bar ── */
  .rw-shop__stock {
    margin-top: -4px;
  }
  .rw-shop__stock-bar {
    height: 2px;
    background: rgba(var(--color-foreground-rgb), 0.18);
    overflow: hidden;
  }
  .rw-shop__stock-fill {
    height: 100%;
    background: var(--color-foreground);
    transition: width 0.3s ease;
  }
  .rw-shop__stock-fill--low {
    background: rgb(var(--color-button));
  }
  .rw-shop__stock-text {
    font-family: var(--font-accent--family);
    font-size: 11px;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: rgba(var(--color-foreground-rgb), 0.62);
    margin-top: 6px;
  }

  /* ── Footer CTA ── */
  .rw-shop__footer {
    display: flex;
    justify-content: center;
    margin-top: 48px;
  }
  .rw-shop__view-all {
    font-family: var(--font-accent--family);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    border: 1px solid var(--color-foreground);
    border-radius: 999px;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    text-decoration: none;
    padding: 18px 28px;
    font-size: 14px;
    background: transparent;
    color: var(--color-foreground);
    transition: transform 0.2s ease;
    cursor: pointer;
    white-space: nowrap;
    line-height: 1;
  }
  .rw-shop__view-all:hover {
    transform: translateY(-2px);
  }

  /* ── Empty state ── */
  .rw-shop__empty {
    grid-column: 1 / -1;
    font-family: var(--font-accent--family);
    color: rgba(var(--color-foreground-rgb), 0.62);
    padding: 48px 0;
    text-align: center;
  }

  /* ── Mobile ── */
  @media (max-width: 989px) {
    .rw-shop__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 749px) {
    .rw-shop {
      padding: 64px 16px;
    }
    .rw-shop__header {
      flex-direction: column;
      align-items: flex-start;
    }
    .rw-shop__filters {
      order: -1;
    }
    .rw-shop__quick-add {
      display: none;
    }
  }
{% endstylesheet %}

{% javascript %}
  (function () {
    function initShop(section) {
      // ── Filter tabs ──────────────────────────────────────────
      var filters = section.querySelectorAll('.rw-shop__filter');
      var grid = section.querySelector('[data-grid]');
      if (filters.length && grid) {
        filters.forEach(function (btn) {
          btn.addEventListener('click', function () {
            filters.forEach(function (b) {
              b.classList.toggle('is-active', b === btn);
            });
            var filter = btn.dataset.filter;
            grid.querySelectorAll('.rw-shop__card').forEach(function (card) {
              card.hidden = filter !== 'all' && card.dataset.type !== filter;
            });
          });
        });
      }

      // ── Size selection + quick-add ───────────────────────────
      section.querySelectorAll('.rw-shop__card').forEach(function (card) {
        var sizeBtns = card.querySelectorAll('.rw-shop__size-btn');
        var addBtn = card.querySelector('.rw-shop__add-btn');
        if (!addBtn) return;

        sizeBtns.forEach(function (sBtn) {
          sBtn.addEventListener('click', function () {
            sizeBtns.forEach(function (b) {
              b.classList.toggle('is-active', b === sBtn);
            });
            addBtn.dataset.variantId = sBtn.dataset.variantId;
            addBtn.disabled = false;
          });
        });

        addBtn.addEventListener('click', function () {
          var variantId = parseInt(addBtn.dataset.variantId, 10);
          if (!variantId) return;
          var origHtml = addBtn.innerHTML;
          addBtn.disabled = true;
          addBtn.textContent = '...';

          fetch('/cart/add.js', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
            body: JSON.stringify({ id: variantId, quantity: 1 }),
          })
            .then(function (r) {
              return r.json();
            })
            .then(function () {
              addBtn.textContent = '✓ Added';
              // Refresh cart badge count
              fetch('/cart.js')
                .then(function (r) {
                  return r.json();
                })
                .then(function (cart) {
                  document.querySelectorAll('.cart-count-bubble span').forEach(function (el) {
                    el.textContent = cart.item_count;
                  });
                  document.dispatchEvent(new CustomEvent('cart:refresh', { bubbles: true }));
                });
              setTimeout(function () {
                addBtn.innerHTML = origHtml;
                addBtn.disabled = false;
                sizeBtns.forEach(function (b) {
                  b.classList.remove('is-active');
                });
                delete addBtn.dataset.variantId;
              }, 1600);
            })
            .catch(function () {
              addBtn.innerHTML = origHtml;
              addBtn.disabled = false;
            });
        });
      });
    }

    document.querySelectorAll('.rw-shop').forEach(initShop);
  })();
{% endjavascript %}

{% schema %}
{
  "name": "RW Shop Floor",
  "tag": "section",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "kicker",
      "label": "Kicker",
      "default": "// CURRENTLY IN STOCK"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "The shop floor"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "max_products",
      "label": "Maximum products",
      "min": 4,
      "max": 12,
      "step": 4,
      "default": 8
    },
    {
      "type": "header",
      "content": "Footer CTA"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Button label",
      "default": "View all pieces"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "Button URL"
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    }
  ],
  "presets": [
    {
      "name": "RW Shop Floor",
      "settings": {
        "kicker": "// CURRENTLY IN STOCK",
        "heading": "The shop floor",
        "max_products": 8,
        "cta_label": "View all pieces"
      }
    }
  ]
}
{% endschema %}
