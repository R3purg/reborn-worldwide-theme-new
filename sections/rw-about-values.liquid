{% liquid
  assign s = section.settings
%}

<section class="rw-about-values color-{{ s.color_scheme }}">
  <div class="rw-about-values__inner">
    <div class="rw-about-values__header">
      <h2 class="rw-about-values__heading">{{ s.heading }}</h2>
      {%- if s.sub_copy != blank -%}
        <span class="rw-about-values__sub">{{ s.sub_copy }}</span>
      {%- endif -%}
    </div>

    {%- if section.blocks.size > 0 -%}
      <div class="rw-about-values__grid">
        {%- for block in section.blocks -%}
          <div class="rw-about-values__card" {{ block.shopify_attributes }}>
            <span class="rw-about-values__index">{{ forloop.index | prepend: '00' | slice: -2, 2 }}</span>
            <h3 class="rw-about-values__title">{{ block.settings.title }}</h3>
            <p class="rw-about-values__body">{{ block.settings.body }}</p>
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</section>

{% stylesheet %}
  .rw-about-values {
    padding: 88px 24px;
  }
  .rw-about-values__inner {
    max-width: 1440px;
    margin-inline: auto;
  }
  .rw-about-values__header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    flex-wrap: wrap;
    gap: 16px;
    margin-bottom: 48px;
  }
  .rw-about-values__heading {
    font-family: var(--font-heading--family);
    font-weight: var(--font-heading--weight);
    text-transform: uppercase;
    font-size: clamp(36px, 6vw, 88px);
    line-height: 0.95;
    margin: 0;
  }
  .rw-about-values__sub {
    font-family: var(--font-accent--family);
    font-size: 11px;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    opacity: 0.6;
    max-width: 320px;
  }
  .rw-about-values__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    border: 1px solid rgba(var(--color-foreground-rgb), 0.18);
  }
  .rw-about-values__card {
    padding: 32px 26px;
    min-height: 280px;
    display: flex;
    flex-direction: column;
    border-right: 1px solid rgba(var(--color-foreground-rgb), 0.18);
  }
  .rw-about-values__card:last-child {
    border-right: 0;
  }
  .rw-about-values__index {
    font-family: var(--font-heading--family);
    font-weight: var(--font-heading--weight);
    font-size: 48px;
    color: rgb(var(--color-button));
  }
  .rw-about-values__title {
    font-family: var(--font-heading--family);
    font-weight: var(--font-heading--weight);
    text-transform: uppercase;
    font-size: 26px;
    margin: 16px 0 12px;
  }
  .rw-about-values__body {
    font-size: 14.5px;
    line-height: 1.6;
    opacity: 0.82;
    margin: 0;
  }
  @media (max-width: 989px) {
    .rw-about-values__grid {
      grid-template-columns: repeat(2, 1fr);
    }
    .rw-about-values__card:nth-child(2) {
      border-right: 0;
    }
    .rw-about-values__card:nth-child(3),
    .rw-about-values__card:nth-child(4) {
      border-top: 1px solid rgba(var(--color-foreground-rgb), 0.18);
    }
  }
  @media (max-width: 749px) {
    .rw-about-values {
      padding: 56px 16px;
    }
    .rw-about-values__grid {
      grid-template-columns: 1fr;
    }
    .rw-about-values__card {
      border-right: 0;
      border-top: 1px solid rgba(var(--color-foreground-rgb), 0.18);
      min-height: 0;
    }
    .rw-about-values__card:first-child {
      border-top: 0;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "RW About values",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "What we stand on"
    },
    {
      "type": "text",
      "id": "sub_copy",
      "label": "Sub copy",
      "default": "Four rules we've never broken, even when it cost us."
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-4"
    }
  ],
  "blocks": [
    {
      "type": "value",
      "name": "Value",
      "limit": 4,
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Make less"
        },
        {
          "type": "textarea",
          "id": "body",
          "label": "Body text",
          "default": "Four chapters a year, 250 pieces each. Scarcity isn't a tactic — it's the only way four people make things they're proud of."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "RW About values",
      "blocks": [
        { "type": "value", "settings": { "title": "Make less", "body": "Four chapters a year, 250 pieces each. Scarcity isn't a tactic — it's the only way four people make things they're proud of." } },
        { "type": "value", "settings": { "title": "By hand", "body": "Every piece pulled on our own screens, water-based ink, in the room we work in. No third-party factory, no middlemen." } },
        { "type": "value", "settings": { "title": "No restocks", "body": "When a chapter sells out, it's gone. The work stays honest because we can't lean on a warehouse of safe reprints." } },
        { "type": "value", "settings": { "title": "From the East", "body": "Born in a Kraków garage, grown across Berlin and Lisbon. The most interesting streetwear isn't where you think it is." } }
      ]
    }
  ]
}
{% endschema %}
