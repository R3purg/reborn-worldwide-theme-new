{% liquid
  assign s = section.settings
%}

<section class="rw-newsletter color-{{ s.color_scheme }}">
  <div class="rw-newsletter__inner">

    <div class="rw-newsletter__kicker">{{ s.kicker }}</div>
    <h2 class="rw-newsletter__heading">
      {{ s.heading_line_1 }}<br>
      <span class="rw-newsletter__heading-accent">{{ s.heading_line_2 }}</span>
    </h2>

    {%- if s.subtext != blank -%}
      <p class="rw-newsletter__subtext">{{ s.subtext }}</p>
    {%- endif -%}

    {%- form 'customer', id: 'rw-newsletter-{{ section.id }}', class: 'rw-newsletter__form' -%}
      <input type="hidden" name="contact[tags]" value="newsletter">

      {%- if form.posted_successfully? -%}
        <div class="rw-newsletter__success">
          <span class="rw-newsletter__success-dot"></span>
          <span>{{ s.success_message }}</span>
        </div>
      {%- else -%}
        <div class="rw-newsletter__field-wrap">
          <label for="rw-nl-{{ section.id }}" class="visually-hidden">{{ 'general.newsletter.email_placeholder' | t }}</label>
          <input
            type="email"
            name="contact[email]"
            id="rw-nl-{{ section.id }}"
            class="rw-newsletter__input"
            placeholder="{{ s.placeholder }}"
            autocomplete="email"
            required
          >
          <button type="submit" class="rw-newsletter__submit">
            {{ s.submit_label }} →
          </button>
        </div>
        {%- if form.errors -%}
          <div class="rw-newsletter__error" role="alert">{{ form.errors | default_errors }}</div>
        {%- endif -%}
      {%- endif -%}
    {%- endform -%}

  </div>

  {%- if s.bg_text != blank -%}
    <div class="rw-newsletter__bg-text" aria-hidden="true">{{ s.bg_text }}</div>
  {%- endif -%}
</section>

{% stylesheet %}
  .rw-newsletter {
    padding: 96px 24px;
    position: relative;
    overflow: hidden;
  }
  .rw-newsletter__inner {
    max-width: 1100px;
    margin-inline: auto;
    text-align: center;
    position: relative;
    z-index: 2;
  }
  .rw-newsletter__kicker {
    font-family: var(--font-accent--family);
    font-size: 11px;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    opacity: 0.6;
    margin-bottom: 18px;
  }
  .rw-newsletter__heading {
    font-family: var(--font-heading--family);
    font-weight: var(--font-heading--weight);
    text-transform: uppercase;
    font-size: clamp(48px, 7vw, 112px);
    line-height: 0.9;
    margin: 0;
  }
  .rw-newsletter__heading-accent {
    color: rgb(var(--color-button));
  }
  .rw-newsletter__subtext {
    font-size: 17px;
    opacity: 0.78;
    max-width: 560px;
    margin: 24px auto 0;
  }
  .rw-newsletter__form {
    margin-top: 32px;
  }
  .rw-newsletter__field-wrap {
    display: flex;
    max-width: 520px;
    margin-inline: auto;
    border: 1px solid rgb(var(--color-background));
    border-radius: 999px;
    overflow: hidden;
  }
  .rw-newsletter__input {
    flex: 1;
    background: transparent;
    border: 0;
    outline: none;
    padding: 18px 22px;
    color: rgb(var(--color-background));
    font-family: var(--font-accent--family);
    font-size: 13px;
    letter-spacing: 0.04em;
    min-width: 0;
  }
  .rw-newsletter__input::placeholder {
    color: rgba(var(--color-background), 0.5);
  }
  .rw-newsletter__submit {
    background: rgb(var(--color-button));
    color: rgb(var(--color-button-label));
    border: 0;
    padding: 0 28px;
    font-family: var(--font-accent--family);
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    white-space: nowrap;
    transition: filter 0.2s ease;
    flex-shrink: 0;
  }
  .rw-newsletter__submit:hover { filter: brightness(1.1); }
  .rw-newsletter__success {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    padding: 22px 28px;
    border: 1px solid rgb(var(--color-button));
    border-radius: 999px;
    font-family: var(--font-accent--family);
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgb(var(--color-background));
  }
  .rw-newsletter__success-dot {
    display: inline-block;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: rgb(var(--color-button));
    flex-shrink: 0;
  }
  .rw-newsletter__error {
    font-family: var(--font-accent--family);
    font-size: 11px;
    letter-spacing: 0.04em;
    color: rgb(var(--color-button));
    margin-top: 12px;
  }
  .rw-newsletter__bg-text {
    position: absolute;
    inset: auto 0 -8% 0;
    text-align: center;
    font-family: var(--font-heading--family);
    font-weight: var(--font-heading--weight);
    text-transform: uppercase;
    font-size: clamp(140px, 22vw, 360px);
    color: rgba(var(--color-background), 0.04);
    white-space: nowrap;
    pointer-events: none;
    line-height: 1;
    z-index: 1;
    user-select: none;
  }
  @media (max-width: 749px) {
    .rw-newsletter { padding: 64px 16px; }
    .rw-newsletter__field-wrap {
      flex-direction: column;
      border-radius: 4px;
      max-width: 100%;
    }
    .rw-newsletter__input {
      border-bottom: 1px solid rgba(var(--color-background), 0.3);
    }
    .rw-newsletter__submit {
      padding: 16px 22px;
      justify-content: center;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "RW Newsletter",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "kicker",
      "label": "Kicker",
      "default": "// SUBSCRIBE FOR NOTHING"
    },
    {
      "type": "text",
      "id": "heading_line_1",
      "label": "Heading line 1",
      "default": "Drops first."
    },
    {
      "type": "text",
      "id": "heading_line_2",
      "label": "Heading line 2 (accent color)",
      "default": "Spam never."
    },
    {
      "type": "textarea",
      "id": "subtext",
      "label": "Subtext",
      "default": "One email per chapter — 24 hours before the public drop. You'll know when. Nobody else will."
    },
    {
      "type": "text",
      "id": "placeholder",
      "label": "Input placeholder",
      "default": "you@somewhere.cool"
    },
    {
      "type": "text",
      "id": "submit_label",
      "label": "Submit button label",
      "default": "Get on the list"
    },
    {
      "type": "text",
      "id": "success_message",
      "label": "Success message",
      "default": "YOU'RE IN. SEE YOU AT THE NEXT DROP."
    },
    {
      "type": "text",
      "id": "bg_text",
      "label": "Background decorative text",
      "default": "REBORN // WORLDWIDE"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-4"
    }
  ],
  "presets": [
    {
      "name": "RW Newsletter"
    }
  ]
}
{% endschema %}
